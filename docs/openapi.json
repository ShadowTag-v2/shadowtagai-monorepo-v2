perationId":"admin_reload_firm_policies_admin_firm_policies_reload_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":true,"type":"object","title":"Response Admin Reload Firm Policies Admin Firm Policies Reload Post"}}}}}}},"/admin/provider-health":{"get":{"tags":["dispatch"],"summary":"Provider Health","description":"Health status of upstream LLM providers with circuit breaker state.","operationId":"provider_health_admin_provider_health_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":true,"type":"object","title":"Response Provider Health Admin Provider Health Get"}}}}}}},"/admin/firm-policy-history/{firm_id}":{"get":{"tags":["dispatch"],"summary":"Firm policy version history","description":"Returns the version history of a firm's policy changes from Firestore.","operationId":"admin_firm_policy_history_admin_firm_policy_history__firm_id__get","parameters":[{"name":"firm_id","in":"path","required":true,"schema":{"type":"string","title":"Firm Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","additionalProperties":true,"title":"Response Admin Firm Policy History Admin Firm Policy History  Firm Id  Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/admin/token-budgets":{"get":{"tags":["dispatch"],"summary":"Token Budgets","description":"Current token budget consumption by tier with Firestore backing.","operationId":"token_budgets_admin_token_budgets_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":true,"type":"object","title":"Response Token Budgets Admin Token Budgets Get"}}}}}}},"/admin/vent-mode/diagnostics":{"get":{"tags":["dispatch"],"summary":"Vent Mode Diagnostics","descrip