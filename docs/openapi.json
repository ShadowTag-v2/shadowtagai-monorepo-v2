{"openapi":"3.1.0","info":{"title":"CounselConduit: Kovel Enclave","description":"Privileged Legal AI under the Kovel Doctrine. Zero-retention architecture.","version":"3.3.2"},"paths":{"/webhooks/stripe":{"post":{"tags":["webhooks"],"summary":"Stripe Webhook","description":"Receive and verify Stripe webhook events.\n\nThe endpoint reads the raw body for HMAC verification,\nthen dispatches to the appropriate event handler.\nReturns 200 immediately — Stripe retries on 4xx/5xx.","operationId":"stripe_webhook_webhooks_stripe_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":true,"type":"object","title":"Response Stripe Webhook Webhooks Stripe Post"}}}}}}},"/connect/onboard":{"post":{"tags":["connect"],"summary":"Create Onboarding Link","description":"Create a Stripe Connect onboarding link for a law firm.\n\n1. Creates a Stripe Connect Custom account for the firm\n2. Stores the account ID in Firestore (beta_accounts collection)\n3. Returns the Stripe-hosted onboarding URL\n\nThe attorney is redirected to Stripe to complete KYC/bank setup.","operationId":"create_onboarding_link_connect_onboard_post","parameters":[{"name":"x-kovel-auth","in":"header","required":false,"schema":{"type":"string","title":"X-Kovel-Auth"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/OnboardingRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/OnboardingResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/connect/status/{account_id}":{"get":{"tags":["Stripe Connect"],"summary":"Get Connect Status","description":"Check the status of an attorney's Stripe Connect account.","operationId":"get_connect_status_connect_status__account_id__get","parameters":[{"name":"account_id","in":"path","required":true,"schema":{"type":"string","title":"Account Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ConnectStatusResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/connect/create-payment-intent":{"post":{"tags":["Stripe Connect"],"summary":"Create Connected Payment","description":"Create a payment intent that sends funds to the attorney's Connect account.\n\nPlatform fee (our cut) is calculated as 15% of the transaction.","operationId":"create_connected_payment_connect_create_payment_intent_post","parameters":[{"name":"amount_cents","in":"query","required":true,"schema":{"type":"integer","title":"Amount Cents"}},{"name":"attorney_account_id","in":"query","required":true,"schema":{"type":"string","title":"Attorney Account Id"}},{"name":"session_id","in":"query","required":true,"schema":{"type":"string","title":"Session Id"}},{"name":"description","in":"query","required":false,"schema":{"type":"string","default":"Legal research session","title":"Description"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","additionalProperties":true,"title":"Response Create Connected Payment Connect Create Payment Intent Post"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/account/delete":{"post":{"tags":["GDPR"],"summary":"Request Account Deletion","description":"Request account deletion (GDPR Article 17 — Right to Erasure).\n\n- Requires explicit confirmation string\n- Rate-limited: 1 request per firm per 24 hours\n- Schedules deletion 30 days out (grace period for undo)\n- Stores soft-delete record in Firestore\n- Schedules Cloud Task for hard deletion\n- Logs to append-only audit trail\n- Sends email receipt (if email provided)","operationId":"request_account_deletion_account_delete_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/DeletionRequest"}}},"required":true},"responses":{"202":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DeletionReceipt"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/account/export":{"post":{"tags":["GDPR"],"summary":"Request Data Export","description":"Request data export (GDPR Article 20 — Right to Portability).\n\nGenerates a download link (signed URL, 24h TTL) for all user data:\n- Profile information\n- Session transcripts (lawyer view only)\n- Billing history\n- Audit log (user's own actions)","operationId":"request_data_export_account_export_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/DataExportRequest"}}},"required":true},"responses":{"202":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":true,"type":"object","title":"Response Request Data Export Account Export Post"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/account/deletion-status/{receipt_id}":{"get":{"tags":["GDPR"],"summary":"Check Deletion Status","description":"Check the status of a pending account deletion.","operationId":"check_deletion_status_account_deletion_status__receipt_id__get","parameters":[{"name":"receipt_id","in":"path","required":true,"schema":{"type":"string","title":"Receipt Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","additionalProperties":true,"title":"Response Check Deletion Status Account Deletion Status  Receipt Id  Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/attestation/generate":{"post":{"tags":["Kovel Attestation"],"summary":"Create Attestation","description":"Generate a new Kovel Attestation Receipt.\n\nThe receipt proves that a privileged attorney-client communication\noccurred via AI under the Kovel doctrine, without storing the\nactual content (only SHA-256 hashes).\n\nRate-limited: 10 requests per minute per firm.","operationId":"create_attestation_attestation_generate_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AttestationRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/SessionAttestation"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/attestation/verify":{"post":{"tags":["Kovel Attestation"],"summary":"Verify Receipt","description":"Verify the integrity of a Kovel Attestation Receipt.","operationId":"verify_receipt_attestation_verify_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/SessionAttestation"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":true,"type":"object","title":"Response Verify Receipt Attestation Verify Post"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/onboarding/create-matter":{"post":{"tags":["Onboarding"],"summary":"Create Matter","description":"Create a new matter and generate a magic link for client onboarding.\n\nThe attorney sends this link to their client. The client clicks it\nto access the ephemeral research portal — no password needed.","operationId":"create_matter_onboarding_create_matter_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/MatterCreateRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MagicLinkResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/onboarding/verify/{token}":{"get":{"tags":["Onboarding"],"summary":"Verify Magic Link","description":"Verify a magic link token and return session parameters.\n\nCalled by the client portal on initial load.\nToken is consumed (single-use) after successful verification.","operationId":"verify_magic_link_onboarding_verify__token__get","parameters":[{"name":"token","in":"path","required":true,"schema":{"type":"string","title":"Token"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MagicLinkVerification"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/vent/start":{"post":{"tags":["Vent Mode"],"summary":"Start Vent Session","description":"Start a Vent Mode intake session.\n\nCreates a Stripe Checkout session for the flat intake fee.\nThe fee goes to the attorney's Stripe Connect account.\nAfter payment, client is redirected to the Vent chat interface.","operationId":"start_vent_session_vent_start_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/VentSessionRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/VentCheckoutResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/vent/message":{"post":{"tags":["Vent Mode"],"summary":"Send Vent Message","description":"Send a message in an active Vent session (non-streaming).","operationId":"send_vent_message_vent_message_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/VentMessage"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":true,"type":"object","title":"Response Send Vent Message Vent Message Post"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/vent/message/stream":{"post":{"tags":["Vent Mode"],"summary":"Stream Vent Message","description":"Stream a Vent Mode response via Server-Sent Events.\n\nReal-time streaming chat interface for empathetic intake.\nUses prompt repetition (arXiv 2512.14982) for accuracy boost.","operationId":"stream_vent_message_vent_message_stream_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/VentMessage"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/vent/summarize":{"post":{"tags":["Vent Mode"],"summary":"Generate Intake Summary","description":"Generate the final intake summary from a completed Vent session.\n\nSent to the attorney dashboard for review.\nTriggers magic-link generation for full Oracle Studio access.","operationId":"generate_intake_summary_vent_summarize_post","parameters":[{"name":"session_id","in":"query","required":true,"schema":{"type":"string","title":"Session Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/VentIntakeSummary"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/tasks/execute-deletion":{"post":{"tags":["Cloud Tasks"],"summary":"Execute Deletion","description":"Execute a GDPR hard delete (called by Cloud Tasks after 30-day grace).\n\nThis endpoint verifies the OIDC token from Cloud Tasks,\nthen deletes all user data across Firestore collections.","operationId":"execute_deletion_tasks_execute_deletion_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":true,"type":"object","title":"Response Execute Deletion Tasks Execute Deletion Post"}}}}}}},"/webhooks/stripe-connect":{"post":{"tags":["Connect Webhooks"],"summary":"Stripe Connect Webhook","description":"Handle Stripe Connect account lifecycle events.\n\nVerifies signature, then dispatches to handler.","operationId":"stripe_connect_webhook_webhooks_stripe_connect_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":true,"type":"object","title":"Response Stripe Connect Webhook Webhooks Stripe Connect Post"}}}}}}},"/webhooks/resend":{"post":{"tags":["Email Webhooks"],"summary":"Resend Webhook","description":"Handle Resend email delivery events.","operationId":"resend_webhook_webhooks_resend_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":true,"type":"object","title":"Response Resend Webhook Webhooks Resend Post"}}}}}}},"/byok/keys":{"post":{"tags":["BYOK"],"summary":"Register Key","description":"Register a BYOK API key for a firm.","operationId":"register_key_byok_keys_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/BYOKKeyRequest"}}},"required":true},"responses":{"201":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/BYOKKeyStatus"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/byok/keys/{firm_id}":{"get":{"tags":["BYOK"],"summary":"List Keys","description":"List all BYOK keys for a firm (masked).","operationId":"list_keys_byok_keys__firm_id__get","parameters":[{"name":"firm_id","in":"path","required":true,"schema":{"type":"string","title":"Firm Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/BYOKKeyListResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/byok/keys/{firm_id}/{provider}":{"delete":{"tags":["BYOK"],"summary":"Revoke Key","description":"Revoke a BYOK key.","operationId":"revoke_key_byok_keys__firm_id___provider__delete","parameters":[{"name":"firm_id","in":"path","required":true,"schema":{"type":"string","title":"Firm Id"}},{"name":"provider","in":"path","required":true,"schema":{"type":"string","title":"Provider"}}],"responses":{"204":{"description":"Successful Response"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/byok/keys/{firm_id}/{provider}/validate":{"post":{"tags":["BYOK"],"summary":"Validate Key","description":"Validate an existing BYOK key by test API call.","operationId":"validate_key_byok_keys__firm_id___provider__validate_post","parameters":[{"name":"firm_id","in":"path","required":true,"schema":{"type":"string","title":"Firm Id"}},{"name":"provider","in":"path","required":true,"schema":{"type":"string","title":"Provider"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","additionalProperties":true,"title":"Response Validate Key Byok Keys  Firm Id   Provider  Validate Post"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/tasks/gdpr/execute-deletion":{"post":{"tags":["gdpr-tasks"],"summary":"Execute Gdpr Deletion","description":"Execute GDPR Article 17 data deletion after 30-day grace period.\n\nThis endpoint is called by Cloud Tasks, NOT directly by users.\nThe 30-day grace period is enforced by the Cloud Tasks scheduler.\n\nDeletion targets (per attorney_id):\n1. kovel_sessions — ephemeral query sessions\n2. audit_logs — usage audit trail (anonymized, not deleted)\n3. billing_events — payment records (retained for tax compliance, anonymized)\n4. beta_accounts — account profile data\n5. stripe_events — webhook event logs for this attorney","operationId":"execute_gdpr_deletion_tasks_gdpr_execute_deletion_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/DeletionPayload"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DeletionResult"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/connect/status":{"get":{"tags":["connect"],"summary":"Check Onboarding Status","description":"Check the Stripe Connect onboarding status for the authenticated attorney.","operationId":"check_onboarding_status_connect_status_get","parameters":[{"name":"x-kovel-auth","in":"header","required":false,"schema":{"type":"string","title":"X-Kovel-Auth"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/OnboardingStatus"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/v1/dispatch":{"post":{"tags":["dispatch"],"summary":"Route a query to the optimal LLM","description":"NadirClaw 3-tier dispatch: classifies prompt complexity (~10ms), selects optimal model based on firm policy + tier + session context, tracks quota, and returns routing decision with cost estimate.","operationId":"dispatch_endpoint_api_v1_dispatch_post","parameters":[{"name":"X-User-Tier","in":"header","required":false,"schema":{"type":"string","default":"trial","title":"X-User-Tier"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/DispatchRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DispatchResponse"}}}},"429":{"description":"Rate limit exceeded"},"503":{"description":"Circuit breaker open"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/admin/metrics":{"get":{"tags":["dispatch"],"summary":"Dispatch metrics for Cloud Monitoring","description":"Returns all NadirClaw dispatch metrics: tier distribution, fallback hits, totals.","operationId":"admin_metrics_endpoint_admin_metrics_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MetricsResponse"}}}}}}},"/admin/models":{"get":{"tags":["dispatch"],"summary":"List available models for subscription tier","description":"Return available models filtered by subscription tier.","operationId":"admin_models_endpoint_admin_models_get","parameters":[{"name":"tier","in":"query","required":false,"schema":{"type":"string","default":"trial","title":"Tier"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/ModelInfoResponse"},"title":"Response Admin Models Endpoint Admin Models Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/admin/firm-policy":{"post":{"tags":["dispatch"],"summary":"Set per-firm model policy and quota","description":"Create or update model routing policy for a specific firm. Controls allowed models and quota limits.","operationId":"a