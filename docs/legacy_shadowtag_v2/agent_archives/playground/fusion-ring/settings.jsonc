{
    // ---------------------------------------------------------
    // 💎 ANTIGRAVITY: GOD MODE (YOLO & AGENT)
    // ---------------------------------------------------------
    // "YOLO Mode": Disables permission prompts for the Agent (Undocumented Feature)
    "geminicodeassist.agentYoloMode": true,
    // Core Agent Settings
    "antigravity.enableAgentMode": true,
    "chat.agent.enabled": true,
    "inlineChat.enableV2": true,
    "inlineChat.mode": "live",
    "chat.edits2.enabled": true,
    // ⚡ SPEED: Auto-accept AI edits after 0.5s and save immediately
    "chat.editing.autoAcceptDelay": 500,
    "chat.editing.alwaysSaveWithGeneratedChanges": true,
    "chat.editing.confirmEditRequestRemoval": false,
    "chat.editing.confirmEditRequestRetry": false,
    // 🔓 AUTHORITY: Allow terminal commands without asking
    "chat.tools.terminal.autoApprove": true,
    "chat.tools.terminal.enableAutoApprove": true,
    // ---------------------------------------------------------
    // ☁️ CLOUD & AUTHENTICATION
    // ---------------------------------------------------------
    "cloudcode.project": "shadowtag-omega-v4",
    "geminicodeassist.project": "shadowtag-omega-v4",
    "google.geminicodeassist.adcPath": "/Users/pikeymickey/.config/gcloud/application_default_credentials.json",
    "google.geminicodeassist.gcloudPath": "/Users/pikeymickey/google-cloud-sdk/bin/gcloud",
    "google.geminicodeassist.selectedProjectId": "shadowtag-omega-v4",
    "cloudcode.releaseChannel": "stable",
    // ---------------------------------------------------------
    // 💾 AUTO-SAVE & FORMATTING (Hands-Free)
    // ---------------------------------------------------------
    "files.autoSave": "onFocusChange",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": false,
    // Default Formatter: Gemini Code Assist
    "editor.defaultFormatter": "google.geminicodeassist",
    // ---------------------------------------------------------
    // 🍞 BREADCRUMBS (Deep Navigation)
    // ---------------------------------------------------------
    "breadcrumbs.enabled": true,
    "breadcrumbs.filePath": "on",
    "breadcrumbs.symbolPath": "on",
    // ---------------------------------------------------------
    // 📝 LANGUAGE SPECIFIC SETTINGS
    // ---------------------------------------------------------
    "files.associations": {
        "*.yml": "yaml",
        "*.yaml": "yaml",
        "*.json": "jsonc",
        "*.code-workspace": "jsonc",
        "*.env": "properties"
    },
    // --- ☕ JAVA (High Performance) ---
    "[java]": {
        "editor.defaultFormatter": "google.geminicodeassist",
        "editor.source.organizeImports": true,
        "breadcrumbs.showClasses": true,
        "breadcrumbs.showMethods": true,
        "breadcrumbs.showInterfaces": true
    },
    "java.import.maven.enabled": false,
    "java.import.gradle.enabled": true,
    "java.import.gradle.offline.enabled": true, // Prevents random download loops
    // --- 🐍 PYTHON ---
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnType": true
    },
    // --- 📄 JSON/YAML ---
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[jsonc]": {
        "workbench.editor.restoreViewState": true,
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[yaml]": {
        "editor.defaultFormatter": "google.geminicodeassist",
        "editor.wordWrap": "on"
    },
    // ---------------------------------------------------------
    // 🛡️ STABILITY & CRASH PREVENTION
    // ---------------------------------------------------------
    // Git: Manual Refresh Only (Prevents 'Extension Host Unresponsive')
    "git.autorefresh": false,
    "git.ignoreLimitWarning": true,
    "git.repositoryScanMaxDepth": 2,
    "git.autofetch": false,
    "git.confirmSync": false,
    // ---------------------------------------------------------
    // 🛡️ CRASH PREVENTION (Updated with Python Fix)
    // ---------------------------------------------------------
    "files.watcherExclude": {
        "**/.venv/**": false, // allow Python extension to resolve local virtualenvs
        "**/__pycache__/**": true,
        "**/node_modules/**": true,
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/dist/**": true,
        "**/build/**": true,
        "**/.gradle/**": true,
        "**/.DS_Store": true
    },
    "search.exclude": {
        "**/.venv": true, // <--- THE FIX
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true
    },
    // NPM: Smart Detection
    "npm.autoDetect": "on",
    "npm.exclude": "**/node_modules/**",
    "npm.scriptExplorerAction": "run",
    // Disable legacy task scanners
    "gulp.autoDetect": "off",
    "grunt.autoDetect": "off",
    "jake.autoDetect": "off",
    "gradle.autoDetect": "off",
    // ---------------------------------------------------------
    // 🐢 VISUALS (No GPU = No Flickering)
    // ---------------------------------------------------------
    "terminal.integrated.gpuAcceleration": "off",
    "terminal.integrated.rendererType": "dom",
    "editor.smoothScrolling": true,
    "editor.fontLigatures": true,
    // Editors: Hex for Binaries, Standard for everything else
    "workbench.editor.defaultBinaryEditor": "hexEditor.hexedit",
    "workbench.editorAssociations": {
        "*.bin": "hexEditor.hexedit",
        "*.dat": "hexEditor.hexedit",
        "*.exe": "hexEditor.hexedit",
        "*.o": "hexEditor.hexedit"
    },
    "geminicodeassist.contextExclusionFile": ".aiexclude",
    "editor.formatOnSaveMode": "modificationsIfAvailable",
    "workbench.colorTheme": "Solarized Light",
    "workbench.trustedDomains.promptInTrustedWorkspace": true,
    "security.workspace.trust.untrustedFiles": "newWindow",
    "redhat.telemetry.enabled": false,
    "extensions.ignoreRecommendations": true,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "[javascript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[dockerfile]": {
        "editor.defaultFormatter": "ms-azuretools.vscode-containers"
    },
    "[pip-requirements]": {},
    "cloudcode.yaml.format.enable": true,
    "cloudcode.yaml.format.singleQuote": true,
    "cloudcode.yaml.trace.server": "verbose",
    "editor.codeActions.triggerOnFocusChange": true,
    "files.autoGuessEncoding": true,
    "notebook.formatOnSave.enabled": true,
    "notebook.multiCursor.enabled": true,
    "terraform.experimentalFeatures.prefillRequiredFields": true,
    "jupyter.interactiveWindow.notebookRepl": true,
    "[markdown]": {
        "editor.unicodeHighlight.ambiguousCharacters": false,
        "editor.unicodeHighlight.invisibleCharacters": false,
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.wordWrap": "on",
        "editor.quickSuggestions": {
            "comments": "off",
            "strings": "off",
            "other": "off"
        },
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
    },
    "typescript.tsserver.web.projectWideIntellisense.suppressSemanticErrors": true,
    "java.import.generatesMetadataFilesAtProjectRoot": true,
    "window.nativeTabs": true,
    "editor.tokenColorCustomizations": {},
    "geminicodeassist.agentDebugMode": true,
    "geminicodeassist.inlineSuggestions.nextEditPredictions": true,
    "geminicodeassist.inlineSuggestions.suggestionSpeed": "Fast",
    "geminicodeassist.chat.changeView": "Default diff view",
    "gemini-cli.debug.logging.enabled": true,
    // =========================================================
    // 1. GOD MODE: PLAYGROUND & EXPERIMENTAL UNLOCKS
    // =========================================================
    // Forces the extension into "Nightly/Insiders" mode to unlock hidden commands
    "geminicodeassist.updateChannel": "Insiders",
    "geminicodeassist.verboseLogging": true,
    "antigravity.showExperimentalFeatures": false,
    // UNLOCKS THE AGENT MANAGER (The "Playground")
    // Source: this.config?.isAgentsEnabled()
    "antigravity.agents.enabled": true,
    "antigravity.agents.maxConcurrentAgents": 5,
    // UNLOCKS "SKILLS" (Custom Tools/Scripts)
    // Source: this.config?.getSkillManager()?.isAdminEnabled()
    "antigravity.skills.enabled": true,
    "antigravity.skills.adminEnabled": true,
    "antigravity.skills.autoRefresh": true,
    "geminicodeassist.agent.planningMode": "detailed", // Forces "Think Step-by-Step"
    "geminicodeassist.agent.autoApprove": true, // DANGER: Use with caution in YOLO mode
    "cSpell.words": [
        "geminicodeassist",
        "pikeymickey",
        "charliermarsh",
        "autorefresh",
        "autofetch",
        "venv",
        "pycache",
