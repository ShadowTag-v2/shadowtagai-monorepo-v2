            "google-developer-knowledge": {
                "serverUrl": "https://developerknowledge.googleapis.com/mcp",
                "headers": {
                    "X-Goog-Api-Key": "***REMOVED_GOOGLE_API_KEY***"
                }
            },
            "postgres": {
                "command": "npx",
                "args": [
                    "-y",
                    "@modelcontextprotocol/server-postgres",
                    "postgresql://user:password@localhost:5432/shadowtag_db"
                ]
            }
        },
        "clientConfig": {
            "features": {
                "iceberg_lake_integration": true,
                "gemini_cli_extension": true
            }
        }
