        "jdwp",
        "temurin",
        "libexec",
        "donot",
        "ZDOTDIR",
        "shadowtagai",
        "RKILL",
        "alloydb",
        "genai",
        "MVSM",
        "imagen",
        "shadowtag",
        "agentic",
        "SHADOWTAG",
        "nowgrep",
        "libnss",
