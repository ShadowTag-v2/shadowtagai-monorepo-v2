    "antigravity.mcp.registry": {
        "mcpServers": {
            "alloydb": {
                "command": "docker",
                "args": [
                    "run",
                    "-i",
                    "--rm",
                    "-e",
                    "GCP_PROJECT=shadowtag-omega-v4",
                    "google/alloydb-mcp-server:latest"
