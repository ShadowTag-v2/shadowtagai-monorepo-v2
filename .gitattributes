# .gitattributes — ShadowTag Monorepo
# LFS rules REMOVED (2026-04-27): LFS budget exceeded, zero tracked objects.
# Binary files are BLOCKED by scripts/prepush-bloat-gate.sh instead.

# Text normalization
* text=auto

# Source code — always LF
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.toml text eol=lf
*.rs text eol=lf
*.go text eol=lf
*.cs text eol=lf
*.graphql text eol=lf
*.gql text eol=lf
*.sql text eol=lf

# Config files
*.env text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf
*.lock text eol=lf linguist-generated

# Binary files — mark as binary, do NOT track with LFS
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
*.avif binary
*.heic binary
*.heif binary
*.mp4 binary
*.mov binary
*.avi binary
*.webm binary
*.wav binary
*.mp3 binary
*.flac binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.psd binary
*.ai binary
*.sketch binary
*.fig binary
*.eps binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.gguf binary
*.safetensors binary
*.onnx binary
*.model binary
*.bin binary

# Generated files — exclude from linguist stats
*.min.js linguist-generated
*.min.css linguist-generated
**/package-lock.json linguist-generated
**/uv.lock linguist-generated
