# ZT.1 Approval Queue — environment variable template
# Copy to .env.local and fill in values. Never commit .env.local.

# FastAPI backend base URL (no trailing slash)
VITE_ZT_API_URL=http://localhost:8000

# Matter UUID to load in the queue UI
VITE_MATTER_ID=

# Approver UUID — the currently authenticated attorney's actor_id
VITE_APPROVER_ID=
