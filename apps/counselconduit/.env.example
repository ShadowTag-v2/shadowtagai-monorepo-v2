# ── CounselConduit Environment Configuration ──
APP_ENV=development
APP_NAME=counselconduit
PORT=8080
LOG_LEVEL=INFO

# ── Google Cloud ──
GOOGLE_CLOUD_PROJECT=shadowtag-omega-v4
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=/Users/pikeymickey/.config/gcloud/application_default_credentials.json

# ── Firebase ──
FIREBASE_PROJECT_ID=shadowtag-omega-v4
FIRESTORE_DATABASE=(default)

# ── CORS ──
CORS_ORIGINS=https://kovelai.web.app,https://kovelai.com,http://localhost:4000

# ── Stripe Billing (Triple-Dip) ──
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SIGNING_SECRET_HERE

# ── Stripe Product IDs ──
STRIPE_PRICE_TRIAL=price_FREE
STRIPE_PRICE_PROFESSIONAL=price_YOUR_PRO_PRICE_ID
STRIPE_PRICE_ENTERPRISE=price_YOUR_ENTERPRISE_PRICE_ID

# ── Kovel Doctrine ──
COUNSELCONDUIT_MODE=stateless
COUNSELCONDUIT_BYOK=true
GCP_KMS_VAULT_SECRET=
