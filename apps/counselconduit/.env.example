# CounselConduit — Staging Environment Template
# Copy to .env and fill in values. NEVER commit .env itself.

# --- GCP ---
GCP_PROJECT_ID=shadowtag-omega-v4
GOOGLE_CLOUD_PROJECT=shadowtag-omega-v4

# --- Stripe (use TEST keys for staging) ---
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_REPLACE_ME

# --- Google Workspace Alerts ---
GOOGLE_CHAT_SPACE=spaces/REPLACE_ME
GMAIL_SENDER=ops@shadowtagai.com
GWS_BIN=/opt/homebrew/bin/gws

# --- LiteLLM ---
GEMINI_API_KEY=REPLACE_ME
LITELLM_MODEL=gemini-3.1-flash-lite-preview

# --- Auth ---
JWT_SECRET=REPLACE_ME_WITH_RANDOM_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=https://cloudtrace.googleapis.com
OTEL_SERVICE_NAME=counselconduit-staging
LOG_LEVEL=INFO

# --- Email ---
FROM_EMAIL=noreply@kovelai.com
FROM_NAME=KovelAI

# --- Firestore ---
FIRESTORE_DATABASE=(default)
