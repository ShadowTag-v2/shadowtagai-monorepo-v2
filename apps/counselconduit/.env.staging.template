# CounselConduit Staging Environment Template
# Copy to .env and fill in values for staging deployment
# NEVER commit the filled .env file

# ── GCP ────────────────────────────────────────────
GCP_PROJECT_ID=shadowtag-omega-v4
APP_ENV=staging

# ── API Keys ───────────────────────────────────────
# Gemini API key for LiteLLM routing
GEMINI_API_KEY=

# ── Stripe (TEST keys only for staging) ────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# ── Resend (email) ─────────────────────────────────
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=

# ── Discord (ops alerts) ──────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Firebase ───────────────────────────────────────
# Firebase Admin SDK uses ADC in Cloud Run
# For local dev, set GOOGLE_APPLICATION_CREDENTIALS
GOOGLE_APPLICATION_CREDENTIALS=

# ── CORS ───────────────────────────────────────────
ALLOWED_ORIGINS=https://kovelai.web.app,https://shadowtagai.web.app,http://localhost:5173

# ── Rate Limiting ──────────────────────────────────
RATE_LIMIT_RPM=60
ATTORNEY_RATE_LIMIT_RPH=100

# ── Cloud Tasks (GDPR) ────────────────────────────
CLOUD_TASKS_QUEUE=counselconduit-gdpr-delete
CLOUD_TASKS_LOCATION=us-central1

# ── OpenTelemetry ──────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=counselconduit-staging

# ── Telemetry Blackout ─────────────────────────────
DISABLE_TELEMETRY=1
DISABLE_ERROR_REPORTING=1
