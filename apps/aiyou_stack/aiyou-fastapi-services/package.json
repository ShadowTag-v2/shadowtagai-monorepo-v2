{
  "name": "shadowtag_v4-fastapi-services",
  "version": "1.0.0",
  "description": "AI Agent system for FastAPI services with System Architect agent and Claude Code development workflows",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "prepublishOnly": "npm run clean && npm run build",
    "example:architect": "npm run build && node dist/examples/system-architect-example.js"
  },
  "keywords": [
    "ai",
    "agent",
    "architecture",
    "claude",
    "fastapi",
    "system-design",
    "agents",
    "development",
    "automation",
    "workflow"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.30",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@types/jest": "^29.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.9.3"
  }
}
