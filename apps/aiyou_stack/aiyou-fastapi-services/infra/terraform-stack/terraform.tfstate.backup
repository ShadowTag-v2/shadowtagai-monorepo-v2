    {
      "mode": "managed",
      "type": "google_workstations_workstation_config",
      "name": "config",
      "provider": "provider[\"registry.terraform.io/hashicorp/google-beta\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "allowed_ports": [
              {
                "first": 22,
                "last": 22
              },
              {
                "first": 80,
                "last": 80
              },
              {
                "first": 1024,
                "last": 65535
              }
            ],
            "annotations": {},
            "conditions": [],
            "container": [
              {
                "args": [],
                "command": [
                  "/bin/bash",
                  "-c",
                  "#!/bin/bash\nset -e\necho \"\u003e\u003e\u003e 🛠️  ShadowTag Workstation Boot...\"\n\n# 1. MOUNT STORAGE (Persistence)\nmkdir -p /mnt/shadow_share\n# Use \\ to escape Terraform and allow Shell expansion\nmount -o nolock \\:/shadow_share /mnt/shadow_share || echo \"Drive already mounted/unavailable.\"\n\n# 2. INSTALL NODE.JS AND NPM (If not present)\nif ! command -v node \u0026\u003e /dev/null; then\n    curl -fsSL https://deb.nodesource.com/setup_20.x | bash -\n    apt-get update \u0026\u0026 apt-get install -y nodejs build-essential\nfi\n\n# 3. ACTIVATE WORKER\nWORKER_DIR=\"/home/user/shadowtag-v2/src/hands\"\nmkdir -p \\\ncd \\\n\n# INJECT WORKER CODE\ncat \u003c\u003cJS \u003e worker.js\n/* eslint-env node */\nconst { Firestore } = require('@google-cloud/firestore');\nconst { chromium } = require('playwright');\n\n// Use process.env to avoid escaping hell\nconst db = new Firestore({ projectId: process.env.PROJECT_ID });\nconst COLLECTION = 'agent_queue';\n\nasync function main() {\n    console.log(\"🚤 Jetski Worker (Playwright) Active. Polling Firestore...\");\n    const query = db.collection(COLLECTION).where('status', '==', 'queued');\n    \n    query.onSnapshot(snapshot =\u003e {\n        snapshot.docChanges().forEach(async change =\u003e {\n            if (change.type === 'added') {\n                await executeMission(change.doc.id, change.doc.data().goal);\n            }\n        });\n    });\n}\n\nasync function executeMission(taskId, goal) {\n    const docRef = db.collection(COLLECTION).doc(taskId);\n    await docRef.update({ status: 'processing', worker: process.env.HOSTNAME });\n    // Use \\ for JS template literal\n    console.log(`Executing Goal: \\`);\n\n    let browser = null;\n    try {\n        browser = await chromium.launch({ headless: true });\n        const page = await browser.newPage();\n        await page.goto('https://example.com');\n        const title = await page.title();\n        const screenshot = await page.screenshot({ type: 'png' });\n        \n        await docRef.update({\n            status: 'completed',\n            result: { title: title, screenshot: screenshot.toString('base64') }\n        });\n        console.log(\"Mission Complete.\");\n    } catch (err) {\n        console.error(err);\n        await docRef.update({ status: 'failed', error: err.message });\n    } finally {\n        if (browser) await browser.close();\n    }\n}\nmain();\nJS\n\ncat \u003c\u003cPKG2 \u003e package.json\n{\n  \"name\": \"jetski-worker\",\n  \"dependencies\": {\n    \"@google-cloud/firestore\": \"^7.0.0\",\n    \"playwright\": \"^1.41.0\"\n  }\n}\nPKG2\n\n# Install deps\nnpm install\nnpx playwright install --with-deps chromium\n\n# Launch\nnohup node worker.js \u003e /var/log/jetski.log 2\u003e\u00261 \u0026\necho \"\u003e\u003e\u003e 🚤 Jetski Deployed.\"\n"
                ],
                "env": {
                  "FILESTORE_IP": "10.5.188.178",
                  "FILE_SHARE_NAME": "shadow_share",
                  "PROJECT_ID": "shadowtag-omega-v2"
                },
                "image": "mcr.microsoft.com/playwright:v1.41.0-jammy",
                "run_as_user": 0,
                "working_dir": ""
              }
            ],
