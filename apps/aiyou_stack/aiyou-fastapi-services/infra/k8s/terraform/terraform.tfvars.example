# Example Terraform Variables for YouAi GKE GPU Infrastructure
# Copy this file to terraform.tfvars and fill in your values

# Required: GCP Project ID
project_id = "youai-production"

# Project naming
project_name = "youai"
region       = "us-central1"
environment  = "production"

# Master authorized networks (who can access GKE control plane)
master_authorized_networks = [
  {
    cidr_block   = "10.0.0.0/8"
    display_name = "Internal Network"
  },
  {
    cidr_block   = "203.0.113.0/24"
    display_name = "Office IP Range"
  }
]

# Monitoring
enable_prometheus = true

# Budget (set to 0 to disable)
billing_account_id = "ABCDEF-123456-789012"
budget_amount      = 50000  # $50,000/month

# Budget notification channels (create these in GCP first)
budget_notification_channels = [
  "projects/youai-production/notificationChannels/1234567890",
]
