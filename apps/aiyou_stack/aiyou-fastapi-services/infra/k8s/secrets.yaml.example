---
# Example secrets file - DO NOT commit with real credentials
# Create actual secrets using: kubectl create secret generic <name> --from-literal=key=value

apiVersion: v1
kind: Secret
metadata:
  name: gemini-api-keys
  namespace: intelligence
type: Opaque
stringData:
  # Replace with actual Gemini API key
  api-key: "REPLACE_WITH_GEMINI_API_KEY"

---
apiVersion: v1
kind: Secret
metadata:
  name: source-api-keys
  namespace: intelligence
type: Opaque
stringData:
  # Replace with actual API keys
  youtube-api-key: "REPLACE_WITH_YOUTUBE_API_KEY"
  twitter-bearer-token: "REPLACE_WITH_TWITTER_BEARER_TOKEN"
  news-api-key: "REPLACE_WITH_NEWS_API_KEY"
