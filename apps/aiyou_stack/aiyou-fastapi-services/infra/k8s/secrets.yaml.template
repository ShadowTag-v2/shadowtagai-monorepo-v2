# =============================================================================
# Kubernetes Secrets Template
# =============================================================================
#
# DO NOT commit actual secrets to git!
# This is a template file showing the structure.
#
# To create secrets:
# 1. Copy this file: cp secrets.yaml.template secrets.yaml
# 2. Replace all placeholder values with actual secrets
# 3. Apply: kubectl apply -f secrets.yaml
# 4. Delete the local file: rm secrets.yaml
#
# Alternative: Create from .env file
# kubectl create secret generic ingestion-secrets \
#   --from-env-file=../.env \
#   --namespace=ingestion-layer
# =============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: ingestion-secrets
  namespace: ingestion-layer
  labels:
    app: gemini-ingestion
    component: secrets
type: Opaque
stringData:
  # AI Integration
  anthropic-api-key: "your_anthropic_api_key_here"
  google-api-key: "your_google_gemini_api_key_here"

  # Multi-Source APIs
  youtube-api-key: "your_youtube_api_key_here"

  twitter-bearer-token: "your_twitter_bearer_token_here"
  twitter-api-key: "your_twitter_api_key_here"
  twitter-api-secret: "your_twitter_api_secret_here"

  news-api-key: "your_news_api_key_here"

  # Database
  database-url: "postgresql://user:password@host:5432/database"

  # Application Security
  secret-key: "your_secret_key_for_jwt_here"
