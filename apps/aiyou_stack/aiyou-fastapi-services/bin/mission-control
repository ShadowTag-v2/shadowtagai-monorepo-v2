#!/usr/bin/env python3
"""
ANTIGRAVITY MISSION CONTROL
Swarm Dispatch Interface (Phase 4)

Usage:
  ./bin/mission-control status
  ./bin/mission-control alpha --topic "Query"
  ./bin/mission-control beta --spec "Microservice Name"
"""
import argparse
import json
import os
import sys
import time
from urllib import request, parse, error

# Configuration
SERVICE_URL = os.environ.get("n-autoresearch/Kosmos/BioAgentsS_URL", "https://n-autoresearch/Kosmos/BioAgentss-server-x6h2e7g3aa-uc.a.run.app")

def print_banner():
    print(r"""
    ___    _   m_   _______ ___________  ___ _   __  _________ _______   __
   /   |  / | / /  /_  __//  _/ ____/  |/  // | / / / ____/  //_/\_   / / /
  / /| | /  |/ /    / /   / // / __/ /|_/ //  |/ / / / __/ ,<    / / / /
 / ___ |/ /|  /    / /  _/ // /_/ / /  / // /|  / / /_/ / /| |  / /_/_/
/_/  |_/_/ |_/    /_/  /___/\____/_/  /_//_/ |_/  \____/_/ |_| /_____/

    :: MISSION CONTROL :: SWARM COMMAND INTERFACE ::
    """)
    print(f"Target: {SERVICE_URL}")
    print("-" * 60)

def check_status():
    """Verify Swarm Health."""
    print("[*] Pinging Swarm...")
    try:
        with request.urlopen(f"{SERVICE_URL}/health") as response:
            if response.status == 200:
                data = json.loads(response.read())
                print(f"[+] STATUS: GREEN | Agents: {data.get('agent_count', 'Unknown')}")
                print(f"[+] Uptime: {data.get('uptime', 'Unknown')}")
            else:
                print(f"[-] STATUS: RED | Code: {response.status}")
    except error.URLError as e:
        print(f"[!] CONNECTION FAILED: {e}")

def dispatch_alpha(topic):
    """
    Mission Alpha: Knowledge Harvest (Grounding Test)
    Cost Budget: $1k Credits
    """
    print(f"[*] DISPATCHING ALPHA MISSION: '{topic}'")
    print("[-] Activating Grounding (Google Search)...")

    payload = {
        "task": f"CONDUCT KNOWLEDGE HARVEST: {topic}",
        "context": {
            "mission_type": "knowledge_harvest",
            "topic": topic,
            "depth": "deep_research",
            "grounding": True
        },
        "require_consensus": True
    }

    _send_mission(payload)

def dispatch_beta(spec):
    """
    Mission Beta: Code Factory (ShadowTag Test)
    Cost Budget: $1.00 (Tier PRO)
    """
    print(f"[*] DISPATCHING BETA MISSION: '{spec}'")
    print("[-] Activating ShadowTag Monetization (Tier: PRO)...")

    payload = {
        "task": f"GENERATE MICROSERVICE: {spec}",
        "context": {
            "mission_type": "code_factory",
            "spec": spec,
            "validation": "shadowtag",
            "cost_tier": "pro"
        },
        "require_consensus": True
    }

    _send_mission(payload)

def _send_mission(payload):
    """Helper to post mission data."""
    try:
        data = json.dumps(payload).encode('utf-8')

        # Check for Auth Token
        headers = {'Content-Type': 'application/json'}
        token = os.environ.get("IDENTITY_TOKEN")
        if token:
            headers['Authorization'] = f"Bearer {token}"
            headers['X-Antigravity-Key'] = "ag_dev_key_123" # Default dev key for server

        req = request.Request(
            f"{SERVICE_URL}/mission",
            data=data,
            headers=headers
        )
        with request.urlopen(req) as response:
            result = json.loads(response.read())
            print(f"[+] MISSION ACCEPTED: ID {result.get('mission_id')}")
            print(json.dumps(result, indent=2))

    except error.HTTPError as e:
        print(f"[!] MISSION REFUSED: {e}")
        try:
            print(e.read().decode())
        except:
            pass
    except Exception as e:
        print(f"[!] ERROR: {e}")

def main():
    print_banner()
    parser = argparse.ArgumentParser(description="Antigravity Mission Control")
    subparsers = parser.add_subparsers(dest="command", help="Command")

    # Status
    subparsers.add_parser("status", help="Check Swarm Status")

    # Alpha
    alpha = subparsers.add_parser("alpha", help="Launch Knowledge Harvest")
    alpha.add_argument("--topic", required=True, help="Research topic")

    # Beta
    beta = subparsers.add_parser("beta", help="Launch Code Factory")
    beta.add_argument("--spec", required=True, help="Software Specification")

    args = parser.parse_args()

    if args.command == "status":
        check_status()
    elif args.command == "alpha":
        dispatch_alpha(args.topic)
    elif args.command == "beta":
        dispatch_beta(args.spec)
    else:
        parser.print_help()

if __name__ == "__main__":
    main()
