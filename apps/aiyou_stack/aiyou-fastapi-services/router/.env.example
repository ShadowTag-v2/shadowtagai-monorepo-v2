# Multi-Model Router Configuration
# Copy to .env and fill in your API keys

# OpenAI (GPT-5, GPT-4, etc.)
OPENAI_API_KEY=sk-REPLACE
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# xAI (Grok)
XAI_API_KEY=xai-REPLACE
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-1

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-REPLACE
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Cheetah (or other fast model via OpenRouter/Groq/Fireworks)
CHEETAH_API_KEY=REPLACE
CHEETAH_BASE_URL=https://api.groq.com/openai/v1
CHEETAH_MODEL=llama-3.1-8b-instant

# Alternative provider (Together, Fireworks, etc.)
ALT_BASE_URL=https://api.together.xyz/v1
ALT_API_KEY=REPLACE
ALT_MODEL=meta-llama/Llama-3.1-70B-Instruct

# Local (Ollama / LM Studio / llama.cpp servers)
LOCAL_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_MODEL=llama3.1

# Router settings
PORT=8787
LOG_LEVEL=info

# Safety: Allowed domains for routing (comma-separated)
# Leave empty to allow all
ALLOWED_DOMAINS=

# Rate limiting (requests per minute)
RATE_LIMIT_RPM=60
