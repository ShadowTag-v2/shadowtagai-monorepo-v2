# Kuvasz Environment Variables
# Copy to .env and customize

# Database Configuration
KUVASZ_DB_PASSWORD=change_this_to_secure_password_min_32_chars

# Application Configuration
KUVASZ_BASE_URL=http://localhost:8080

# Notification Channels (optional - configure as needed)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK
# PAGERDUTY_INTEGRATION_KEY=your_pagerduty_integration_key

# Email Notifications (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM=monitoring@shadowtag.ai
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_specific_password
