# API Keys and Secrets for Intelligence Pipeline
# IMPORTANT: This is an example file. Create actual secrets.yaml and DO NOT commit to git.
# Use: kubectl create secret generic api-keys --from-env-file=.env -n intelligence-pipeline

apiVersion: v1
kind: Secret
metadata:
  name: api-keys
  namespace: intelligence-pipeline
type: Opaque
stringData:
  # Anthropic API Key for JR Engine and Cor Brain
  ANTHROPIC_API_KEY: "sk-ant-api03-..."

  # GCP Project ID
  PROJECT_ID: "your-gcp-project-id"

  # BigQuery Configuration
  BIGQUERY_DATASET: "pnkln_intelligence"

  # GCS Bucket
  GCS_BUCKET: "your-project-id-pnkln-intelligence"

  # GitHub Token (optional, for creating issues)
  GITHUB_TOKEN: "ghp_..."

  # Slack Webhook (optional, for notifications)
  SLACK_WEBHOOK_URL: "https://hooks.slack.com/services/..."

  # Email Configuration (optional, for briefing delivery)
  SMTP_HOST: "smtp.gmail.com"
  SMTP_PORT: "587"
  SMTP_USER: "intelligence@pnkln.ai"
  SMTP_PASSWORD: "..."
  CEO_EMAIL: "ceo@pnkln.ai"

  # Scraper Configuration
  SCRAPER_USER_AGENT: "PNKLN-Intelligence-Bot/1.0 (+https://pnkln.ai/bot-policy)"
  SCRAPER_CONTACT: "intelligence@pnkln.ai"
  RESPECT_ROBOTS_TXT: "true"
  DEFAULT_CRAWL_DELAY: "3.0"

---
# To create the secret from command line:
# kubectl create secret generic api-keys \
#   --from-literal=ANTHROPIC_API_KEY="sk-ant-api03-..." \
#   --from-literal=PROJECT_ID="your-gcp-project-id" \
#   --from-literal=BIGQUERY_DATASET="pnkln_intelligence" \
#   --from-literal=GCS_BUCKET="your-project-id-pnkln-intelligence" \
#   -n intelligence-pipeline

# Or from .env file:
# kubectl create secret generic api-keys --from-env-file=.env -n intelligence-pipeline
