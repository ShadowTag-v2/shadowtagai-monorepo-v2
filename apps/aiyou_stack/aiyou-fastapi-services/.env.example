# ShadowTag Configuration
SHADOWTAG_ENABLED=true
SHADOWTAG_KEY_PATH=./keys/shadowtag.key

# NS (Semantic Memory) Configuration
NS_ENABLED=true
NS_VECTOR_DB_PATH=./data/ns_vectors.db
TARGET_P99_LATENCY_MS=90  # Target: <90ms for 99th percentile
TARGET_PRB_COVERAGE=0.98  # Target: 98% probability coverage

# Judge #6 (JR Engine) Configuration
JR_VALIDATION_ENABLED=true
JR_AUDIT_LOG_PATH=./logs/jr_audit.log

# ShadowTag (Cryptographic Watermarking) Configuration
SHADOWTAG_ENABLED=true
SHADOWTAG_KEY_PATH=./keys/shadowtag.key

# NS (Neural Search / Semantic Memory) Configuration
NS_ENABLED=true
NS_VECTOR_DB_PATH=./data/ns_vectors.db

# COR (Chain of Reasoning) Configuration
COR_ENABLED=true
COR_MAX_DEPTH=5

# DTE (Dynamic Trust Evolution) Configuration
DTE_ENABLED=true
DTE_LEARNING_RATE=0.01
DTE_EVOLUTION_THRESHOLD=0.05

# Glicko-2 Rating System Configuration
GLICKO2_ENABLED=true
GLICKO2_INITIAL_RATING=1500
GLICKO2_INITIAL_RD=350

# Multi-Agent Debate Configuration
DEBATE_ENABLED=true
DEBATE_NUM_AGENTS=3
DEBATE_MAX_ROUNDS=5

# GRPO (Generalized Reinforcement from Policy Optimization) Configuration
GRPO_ENABLED=true
GRPO_LEARNING_RATE=0.001
GRPO_BATCH_SIZE=32

# Wealth Planning Configuration
WEALTH_MODEL_ENABLED=true
WEALTH_LEAK_DETECTION=true
