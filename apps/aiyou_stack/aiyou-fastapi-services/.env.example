# Google Gemini API Configuration
# PNKLN Intelligence Pipeline + Kosmos + YouAi Governance - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# GCP Settings
# ============================================================================
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id  # Alias for Kosmos
GCP_LOCATION=us-central1
GCP_REGION=us-central1

# GCS Buckets
GCP_GCS_BUCKET_RAW=pnkln-code-storage-prod
GCP_GCS_BUCKET_PROCESSED=pnkln-code-storage-prod
STORAGE_BUCKET=your-project-id-kosmos-artifacts  # Kosmos artifacts

# BigQuery
GCP_BIGQUERY_DATASET=code_search
GCP_BIGQUERY_LOCATION=US

# Firestore (for Kosmos world model)
FIRESTORE_DATABASE=(default)

# Vertex AI Vector Search
GCP_VERTEX_AI_INDEX_DISPLAY_NAME=code-embeddings-index
GCP_VERTEX_AI_ENDPOINT_DISPLAY_NAME=code-search-endpoint
GCP_VERTEX_AI_EMBEDDING_DIMENSIONS=1536
GCP_VERTEX_AI_MACHINE_TYPE=e2-standard-16
GCP_VERTEX_AI_MIN_REPLICAS=2
GCP_VERTEX_AI_MAX_REPLICAS=10

# ============================================================================
# Embedding Settings
# ============================================================================
EMBEDDING_PROVIDER=openai  # Options: openai, voyage, codebert
EMBEDDING_MODEL_NAME=text-embedding-3-large  # OpenAI: text-embedding-3-large, Voyage: voyage-code-2
EMBEDDING_DIMENSIONS=1536  # 768 for CodeBERT, 1536 for OpenAI, 1536 for Voyage
EMBEDDING_BATCH_SIZE=100
EMBEDDING_CHUNK_SIZE=1500
EMBEDDING_CHUNK_OVERLAP=300

# API Keys
EMBEDDING_OPENAI_API_KEY=sk-...
EMBEDDING_VOYAGE_API_KEY=pa-...
EMBEDDING_ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# arXiv Settings
# ============================================================================
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL,cs.DC,cs.SE
ARXIV_MAX_RESULTS_PER_QUERY=100
ARXIV_DELAY_SECONDS=3.0
ARXIV_NUM_RETRIES=5
ARXIV_DOWNLOAD_PDF=true
ARXIV_PAPERS_DIRECTORY=./data/papers

# ============================================================================
# Reddit Settings
# ============================================================================
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=PNKLN Intelligence Bot 1.0
REDDIT_SUBREDDITS=MachineLearning,kubernetes,MLOps,deeplearning,artificial,datascience
REDDIT_POSTS_LIMIT=25

# ============================================================================
# Hacker News Settings
# ============================================================================
HN_API_BASE_URL=http://hn.algolia.com/api/v1
HN_SEARCH_KEYWORDS=machine learning,artificial intelligence,kubernetes,MLOps,LLM
HN_MAX_RESULTS=100
HN_MIN_POINTS=10

# ============================================================================
# Ingestion Settings
# ============================================================================
INGESTION_REPOSITORIES_CONFIG=pnkln_intelligence/config/repositories.yaml
INGESTION_FLATTENING_TOOL=repomix  # Options: repomix, gitingest
INGESTION_OUTPUT_FORMAT=xml  # Options: xml, markdown, json, plain
INGESTION_INCLUDE_SECURITY_SCAN=true
INGESTION_MAX_FILE_SIZE_MB=10

# Repomix-specific
INGESTION_REPOMIX_COMPRESSION=true
INGESTION_REPOMIX_TOKEN_ENCODER=cl100k_base  # Options: cl100k_base (GPT-4), o200k_base (Claude)

# ============================================================================
# Kosmos Agent Settings
# ============================================================================
# Model Configuration
DEFAULT_MODEL=gemini-2.0-flash-exp
# Options: gemini-2.0-flash-exp (recommended, 15-20% cost reduction), gemini-1.5-pro (complex reasoning)
GEMINI_PRO_MODEL=gemini-1.5-pro  # For complex reasoning tasks
GEMINI_FLASH_MODEL=gemini-2.0-flash-exp  # For cost efficiency (default)

# AgentOps (optional - for observability)
AGENTOPS_API_KEY=your-agentops-api-key

# OpenTelemetry / Tracing
ENABLE_TELEMETRY=true

# Budget Controls
DAILY_BUDGET=2000.0
MONTHLY_BUDGET=60000.0
SESSION_BUDGET=500.0
ALERT_THRESHOLD=0.8

# ============================================================================
# Monitoring Settings
# ============================================================================
MONITORING_ENABLE_PROMETHEUS=true
MONITORING_PROMETHEUS_PORT=8000

# Alert Thresholds
MONITORING_VECTOR_SEARCH_P95_LATENCY_MS=200
MONITORING_INGESTION_ERROR_RATE_PERCENT=1.0
MONITORING_DAILY_COST_INCREASE_PERCENT=20.0
MONITORING_INDEX_STALENESS_HOURS=24

# Logging
LOG_LEVEL=INFO

# ============================================================================
# Pipeline Settings
# ============================================================================
PROCESSING_MODE=hybrid  # Options: batch, streaming, hybrid
BATCH_SCHEDULE_CRON=0 2 * * *  # Daily at 2 AM

# ============================================================================
# YouAi Governance Service Settings
# ============================================================================
# Environment Configuration
ENVIRONMENT=development
DEBUG=true

# Service Configuration
SERVICE_NAME=youai-governance-service
SERVICE_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://youai:youai_password@localhost:5432/youai_governance
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production
API_KEY_HEADER=X-API-Key
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
ENABLE_METRICS=true
ENABLE_TRACING=true
LOG_LEVEL=INFO

# Governance Thresholds
EU_AI_ACT_ENABLED=true
DSA_VLOP_MODE=false
NIST_RMF_ENABLED=true
ISO_42001_ENABLED=true

# Content Safety
BRAND_SAFETY_THRESHOLD=0.85
CONTENT_MODERATION_ENABLED=true
C2PA_VERIFICATION_ENABLED=true

# Adtech Compliance
VAST_VERSION=4.3
OM_SDK_ENABLED=true
PRIVACY_SANDBOX_ENABLED=true

# Accessibility
WCAG_LEVEL=AA
COPPA_MODE_ENABLED=true
AGE_VERIFICATION_REQUIRED=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Feature Flags
BLOCKCHAIN_INTEGRATION_ENABLED=false
PERSONA_IQ_OVERRIDE=160
