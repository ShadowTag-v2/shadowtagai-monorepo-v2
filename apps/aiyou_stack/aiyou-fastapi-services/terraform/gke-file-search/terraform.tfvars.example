# ============================================================================
# TERRAFORM VARIABLES - EXAMPLE CONFIGURATION
# ============================================================================
# Copy this file to terraform.tfvars and customize for your environment
# cp terraform.tfvars.example terraform.tfvars
# ============================================================================

# ============================================================================
# PROJECT CONFIGURATION
# ============================================================================

project_id  = "pnkln-core-gke"
region      = "us-central1"  # Recommend us-central1 for Hypercomputer access
environment = "prod"          # Options: dev, staging, prod

# ============================================================================
# GKE CLUSTER CONFIGURATION
# ============================================================================

cluster_name    = "pnkln-core-cluster"
network_name    = "pnkln-vpc"
subnetwork_name = "pnkln-gke-subnet"

# Node pool configuration
node_pool_config = {
  machine_type   = "n2-standard-8"   # 8 vCPU, 32GB RAM - optimized for Judge 6
  min_nodes      = 3                 # High availability minimum
  max_nodes      = 10                # Auto-scale to handle traffic spikes
  disk_size_gb   = 100               # SSD for fast I/O
  disk_type      = "pd-ssd"
  preemptible    = false             # Use standard instances for prod
  spot           = false             # Disable spot instances for reliability
}

# ============================================================================
# VERTEX AI / FILE SEARCH CONFIGURATION
# ============================================================================

rag_chunk_size    = 512   # Optimal for policy documents
rag_chunk_overlap = 100   # Preserve context across chunks

enable_file_search = true

# ============================================================================
# GCS BUCKET CONFIGURATION
# ============================================================================

bucket_prefix           = "pnkln-policy-corpus"
enable_bucket_versioning = true  # Required for regulatory compliance

# Lifecycle rules for cost optimization
bucket_lifecycle_rules = [
  {
    action = {
      type = "Delete"
    }
    condition = {
      num_newer_versions = 5        # Keep last 5 versions
      with_state        = "ARCHIVED"
    }
  }
]

# ============================================================================
# WORKLOAD IDENTITY CONFIGURATION
# ============================================================================

workload_identity_namespace = "pnkln-core"
kubernetes_sa_name          = "pnkln-file-search-sa"

# ============================================================================
# PERFORMANCE & MONITORING
# ============================================================================

enable_monitoring = true
enable_logging    = true

# Latency SLA thresholds (milliseconds)
latency_sla = {
  judge_p99           = 90    # Judge 6 must respond in ≤90ms (p99)
  file_search_p99     = 1000  # File Search acceptable at ≤1000ms (p99)
  total_acceptable    = 850   # Total user-facing latency target
}

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

enable_binary_authorization = true   # Verify container images
enable_shielded_nodes       = true   # Hardware-level security
enable_pod_security_policy  = true   # Enforce pod security standards

# ============================================================================
# COST OPTIMIZATION
# ============================================================================

enable_autopilot          = false  # Use standard GKE for more control
enable_cluster_autoscaling = true  # Auto-scale nodes based on demand

budget_alert_threshold = 5000  # Alert if monthly cost exceeds $5000 USD

# ============================================================================
# DEVELOPMENT/STAGING OVERRIDE EXAMPLE
# ============================================================================
# For dev/staging environments, consider these cost optimizations:
#
# environment = "dev"
#
# node_pool_config = {
#   machine_type   = "n2-standard-4"  # Smaller instances
#   min_nodes      = 1
#   max_nodes      = 3
#   disk_size_gb   = 50
#   disk_type      = "pd-standard"    # Standard disk vs SSD
#   preemptible    = true             # Use preemptible instances
#   spot           = true
# }
#
# enable_binary_authorization = false  # Disable for faster iteration
# ============================================================================
