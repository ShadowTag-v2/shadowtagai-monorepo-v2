# TEMPLATE: Copy to 05-secrets.yaml and fill in actual API keys
# DO NOT commit this file with real keys to git!
#
# Create secrets with:
#   kubectl create secret generic api-keys \
#     --from-literal=google-api-key=$GOOGLE_API_KEY \
#     --from-literal=anthropic-api-key=$ANTHROPIC_API_KEY \
#     --from-literal=openai-api-key=$OPENAI_API_KEY \
#     --from-literal=xai-api-key=$XAI_API_KEY \
#     --from-literal=perplexity-api-key=$PERPLEXITY_API_KEY \
#     --from-literal=api-keys=$API_KEYS \
#     --namespace=consensus

apiVersion: v1
kind: Secret
metadata:
  name: api-keys
  namespace: consensus
type: Opaque
stringData:
  google-api-key: "YOUR_GOOGLE_API_KEY"
  anthropic-api-key: "YOUR_ANTHROPIC_API_KEY"
  openai-api-key: "YOUR_OPENAI_API_KEY"
  xai-api-key: "YOUR_XAI_API_KEY"
  perplexity-api-key: "YOUR_PERPLEXITY_API_KEY"
  api-keys: "key1,key2,key3"  # Comma-separated API keys for client authentication
