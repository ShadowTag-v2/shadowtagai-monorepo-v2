# LLM Provider API Keys (optional - works without them in mock mode)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Router Configuration
USE_MOCK=1                    # 1=mock, 0=real providers
DEFAULT_PROVIDER=mock         # mock|openai|anthropic|auto

# Rate Limiting (requests per second)
RATE_LIMIT_RPS=6.6
RATE_LIMIT_CONCURRENT=2

# Judge #6 Governance
ENABLE_GOVERNANCE=1           # 1=enforce, 0=permissive
COR_INSTANCE_ID=copilot-001

# Logging
LOG_LEVEL=info                # debug|info|warn|error
LOG_REQUESTS=1
LOG_PATCHES=1

# Editor Integration
EDITOR_TIMEOUT_MS=5000
MAX_FILE_SIZE_KB=500
