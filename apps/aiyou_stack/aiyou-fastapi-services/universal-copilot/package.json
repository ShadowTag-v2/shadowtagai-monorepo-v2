{
  "name": "@pnkln/universal-copilot",
  "version": "1.0.0",
  "description": "Compliant multi-LLM code assistant with Judge 6 governance",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/widget.ts",
    "build": "tsc",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:ci": "NODE_ENV=test USE_MOCK=1 vitest run --coverage --reporter=verbose",
    "test:mock": "USE_MOCK=1 npm test",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "keywords": [
    "ai",
    "copilot",
    "code-assistant",
    "llm",
    "governance",
    "Cor.Claude_Code_6"
  ],
  "author": "Erik Bjontegard, Pnkln",
  "license": "UNLICENSED",
  "dependencies": {
    "zod": "^3.23.8",
    "bottleneck": "^2.19.5",
    "openai": "^4.56.0",
    "@anthropic-ai/sdk": "^0.27.0",
    "diff": "^5.2.0",
    "patch": "^0.5.1"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "tsx": "^4.19.1",
    "vitest": "^2.1.1",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
