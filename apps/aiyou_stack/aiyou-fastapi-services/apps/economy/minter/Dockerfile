FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the entire monorepo context to access libs
COPY . .

# Environment variables
ENV PORT=8080

# Run the service
CMD ["uvicorn", "apps.economy.minter.main:app", "--host", "0.0.0.0", "--port", "8080"]
