{
  "name": "@antigravity/gitnexus-integration",
  "version": "1.0.0",
  "description": "GitNexus codebase knowledge graph — folded into Monorepo-Uphillsnowball",
  "private": true,
  "scripts": {
    "setup": "npm install && npx nexus setup ../../ --output .nexus",
    "serve": "npx nexus serve --port 3742",
    "mcp": "npx nexus mcp",
    "index": "npx nexus analyze ../../ --langs ts,tsx,py,js"
  },
  "dependencies": {
    "gitnexus": "latest"
  },
  "engines": {
    "node": ">=18"
  },
  "nexus": {
    "root": "../../",
    "outputDir": ".nexus",
    "languages": [
      "typescript",
      "python",
      "javascript"
    ],
    "exclude": [
      "node_modules",
      "data/drive_ingest",
      "data/web_ingest",
      "data/alphaxiv",
      "artifacts/workspace_archive"
    ]
  }
}
