{
  "displayName": "KovelAI Revision Critical Errors",
  "userLabels": {},
  "conditions": [
    {
      "displayName": "Log match condition",
      "conditionThreshold": {
        "filter": "metric.type=\"logging.googleapis.com/user/critical_error_count\" AND resource.type=\"cloud_run_revision\"",
        "aggregations": [
          {
            "alignmentPeriod": "300s",
            "crossSeriesReducer": "REDUCE_SUM",
            "perSeriesAligner": "ALIGN_SUM"
          }
        ],
        "comparison": "COMPARISON_GT",
        "duration": "0s",
        "trigger": {
          "count": 1
        },
        "thresholdValue": 0
      }
    }
  ],
  "alertStrategy": {
    "autoClose": "604800s"
  },
  "combiner": "OR",
  "enabled": true,
  "notificationChannels": []
}
