# ════════════════════════════════════════════════════════════
# KovelAI — Environment Configuration
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────
PORT=8080
LOG_LEVEL=info

# ── Kovel Shield (Cryptographic Signing) ─────────────────
# HMAC secret for signing query results (Kovel Doctrine compliance)
# Rotate this key quarterly. MUST be 32+ characters.
KOVEL_KMS_SECRET=change-me-in-production-minimum-32-characters

# ── Stripe Connect (Payment Routing) ────────────────────
# From: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# SaaS tier price IDs (from Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_SOVEREIGN=price_xxx

# ── Google AI (Gemini Model Calls) ──────────────────────
# Service account JSON path (for Cloud Run / Docker)
GOOGLE_APPLICATION_CREDENTIALS=/app/sa-key.json
# Or direct API key
GOOGLE_API_KEY=AIza_xxx

# ── Nginx (Reverse Proxy) ──────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
TLS_CERT_DIR=./certs

# ── CRM Integration (Optional) ─────────────────────────
# Clio or PracticePanther OAuth credentials for conflict checking
CRM_CLIENT_ID=
CRM_CLIENT_SECRET=
CRM_REDIRECT_URI=https://kovelai.com/api/v1/crm/callback
