# KovelAI — Build-time Environment Variables
# Copy to .env.local and fill in values for local development.
# Static export: only NEXT_PUBLIC_* variables are available at runtime.

# Application Core
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Analytics (optional — GA4 Measurement ID)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Stripe (publishable key only — secret key lives in Cloud Run)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Lead Capture API (Cloud Run endpoint)
NEXT_PUBLIC_LEAD_CAPTURE_URL="https://capturelead-767252945109.us-central1.run.app"
