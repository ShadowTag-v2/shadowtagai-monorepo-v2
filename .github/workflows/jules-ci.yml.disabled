name: Jules Asynchronous DevOps Protocol (Archon Pattern)
on:
  push:
    branches: [ main ]

jobs:
  jules-deploy:
    runs-on: ubuntu-latest
    permissions:
      contents: 'read'
      id-token: 'write'

    steps:
      - uses: actions/checkout@v4
      - uses: oven-sh/setup-bun@v1

      - name: GCP Auth (Workload Identity)
        uses: google-github-actions/auth@v2
        with:
          project_id: 'shadowtag-omega-v4'
          workload_identity_provider: 'projects/${{ secrets.GCP_PROJECT_NUMBER }}/locations/global/workloadIdentityPools/github/providers/shadowtag'

      - name: V19 Empirical FinOps Circuit Breaker
        run: bun run tools/finops/finops_governor.ts

      - uses: google-labs-code/action-setup@v1
      - name: Delegate to Jules Subagent
        uses: google-labs-code/jules-action@v1
        with:
          internal_model: "Claude Opus 4.6"
          agent_directive: |
            You are the Jules DevOps Subagent powered by Claude Opus 4.6.
            1. Verify the Bun Relay build in the Kriasoft chassis.
            2. Validate the GraphQL schema against Spanner DDL in shadowtag-omega-v4.
            3. Deploy the unified Hono container to Cloud Run.
          skills_repo: 'google-labs-code/jules-skills'
