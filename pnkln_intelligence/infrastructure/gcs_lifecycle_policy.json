{
  "lifecycle": {
    "rule": [
      {
        "action": {
          "type": "SetStorageClass",
          "storageClass": "NEARLINE"
        },
        "condition": {
          "age": 30,
          "matchesPrefix": ["raw/repositories/"]
        },
        "description": "Move raw repository snapshots to Nearline after 30 days"
      },
      {
        "action": {
          "type": "SetStorageClass",
          "storageClass": "COLDLINE"
        },
        "condition": {
          "age": 90,
          "matchesPrefix": ["raw/repositories/"]
        },
        "description": "Move raw repository snapshots to Coldline after 90 days"
      },
      {
        "action": {
          "type": "Delete"
        },
        "condition": {
          "age": 365,
          "matchesPrefix": ["logs/ingestion/"]
        },
        "description": "Delete ingestion logs older than 1 year"
      },
      {
        "action": {
          "type": "Delete"
        },
        "condition": {
          "age": 180,
          "matchesPrefix": ["indexes/vector_search_snapshots/"],
          "numNewerVersions": 3
        },
        "description": "Delete old vector search index snapshots, keep 3 most recent"
      },
      {
        "action": {
          "type": "SetStorageClass",
          "storageClass": "ARCHIVE"
        },
        "condition": {
          "age": 365,
          "matchesPrefix": ["raw/research_papers/"]
        },
        "description": "Archive research papers older than 1 year"
      }
    ]
  }
}
