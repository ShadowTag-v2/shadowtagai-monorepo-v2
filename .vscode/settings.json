{
  "editor.formatOnSave": true,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.analysis.typeCheckingMode": "basic",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  // Ruff VSCode Extension — https://github.com/astral-sh/ruff-vscode
  // Uses native ruff server (replaces deprecated ruff-lsp)
  "ruff.nativeServer": "on",
  "ruff.lint.run": "onType",
  "ruff.organizeImports": true,
  "ruff.fixAll": true,
  "ruff.importStrategy": "fromEnvironment",
  "ruff.showNotifications": "onWarning",
  "ruff.path": ["${workspaceFolder}/.venv/bin/ruff"],
  "ruff.configuration": "${workspaceFolder}/ruff.toml",
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnSave": true
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/node_modules": true,
    "**/reference_architectures": true,
    "**/external_repos": true,
    "**/external_sdks": true,
    "**/.mypy_cache": true,
    "**/.pixi": true,
    "**/deep-archive": true,
    "**/archive": true,
    "**/bazel-*": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/reference_architectures": true,
    "**/external_repos": true,
    "**/external_sdks": true,
    "**/.venv": true,
    "**/.mypy_cache": true,
    "**/__pycache__": true,
    "**/deep-archive": true,
    "**/archive": true,
    "**/build": true,
    "**/dist": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/.venv/**": true,
    "**/.venv*/**": true,
    "**/.pixi/**": true,
    "**/.mypy_cache/**": true,
    "**/__pycache__/**": true,
    "**/clones/**": true,
    "**/clone-base/**": true,
    "**/reference_architectures/**": true,
    "**/external_repos/**": true,
    "**/external_sdks/**": true,
    "**/deep-archive/**": true,
    "**/archive/**": true,
    "**/build/**": true,
    "**/dist/**": true,
    "**/.gradle/**": true,
    "**/.lancedb/**": true,
    "**/.gitnexus/**": true,
    "**/.chroma_db/**": true,
    "**/.uv-cache/**": true,
    "**/third_party/**": true,
    "**/bazel-*/**": true,
    "**/.ruff_cache/**": true,
    "**/.pytest_cache/**": true
  },
  "terminal.integrated.env.osx": {
    "NODE_OPTIONS": "--no-deprecation"
  },
  "terminal.integrated.env.linux": {
    "NODE_OPTIONS": "--no-deprecation"
  },
  "cloudcode.project": "shadowtag-omega-v4",
  "cloudcode.region": "us-central1",
  "extensions.autoUpdate": false,
  "extensions.autoCheckUpdates": false
}
