{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "telemetry.telemetryLevel": "off",
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3.14",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.exclude": [
    "**/external_repos/**",
    "**/archive/**",
    "**/_archive*/**",
    "**/node_modules/**",
    "**/.venv/**",
    "**/control/**",
    "**/*legacy*/**",
    "**/third_party/**",
    "**/vendor/**"
  ],
  "ty.interpreterPath": "/opt/homebrew/bin/python3.14",
  "files.exclude": {
    "**/external_repos/**": true,
    "**/_archive*/**": true,
    "**/.hypothesis/**": true,
    "**/.mypy_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/.pytest_cache/**": true,
    "**/__pycache__/**": true
  },
  "search.exclude": {
    "**/external_repos/**": true,
    "**/archive/**": true,
    "**/_archive*/**": true,
    "**/node_modules/**": true,
    "**/.venv/**": true,
    "**/third_party/**": true,
    "**/*.lock": true,
    "**/coverage.xml": true
  },
  "dart.analysisExcludedFolders": [
    "external_repos",
    "archive",
    "node_modules",
    ".venv",
    "build",
    "third_party"
  ],
  "cmake.configureOnOpen": false,
  "cmake.autoSelectActiveFolder": false,
  "makefile.configureOnOpen": false,
  "java.configuration.checkProjectSettingsExclusions": false,
  "python.venvPath": "${workspaceFolder}",
  "python.venvFolders": [
    ".venv"
  ],
  "python-envs.defaultInterpreterPath": "/opt/homebrew/bin/python3.14"
}