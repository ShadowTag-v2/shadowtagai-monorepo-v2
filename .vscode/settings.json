{
  "editor.formatOnSave": true,
  "python.languageServer": "Pylance",
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3.14",
  "git.decorations.enabled": false,
  "cSpell.ignorePaths": [
    "**/dist-runtime/**",
    "**/.agent/incoming_repos/**",
    "**/vendor/a2ui/**",
    "**/payload-starter/**"
  ],
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/dist-runtime/**": true,
    "**/.pixi/**": true,
    "**/.venv/**": true
  },
  "extensions.experimental.affinity": {
    "google.geminicodeassist": 1,
    "googlecloudtools.cloudcode": 1,
    "mtxr.sqltools": 2
  },
  "telemetry.telemetryLevel": "off"
}
