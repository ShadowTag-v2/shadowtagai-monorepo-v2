{
  "editor.formatOnSave": true,
  "python.languageServer": "Pylance",
  "python.defaultInterpreterPath": "",
  "git.decorations.enabled": false,
  "cSpell.ignorePaths": [
    "**/dist-runtime/**",
    "**/.agent/incoming_repos/**",
    "**/vendor/a2ui/**",
    "**/payload-starter/**"
  ],
  "dart.analysisExcludedFolders": ["tools/dio", "tools/google-cloud-dart", "external_repos"],
  "files.watcherExclude": {
    "**/external_repos/**": true,
    "**/tools/dio/**": true,
    "**/tools/google-cloud-dart/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/dist-runtime/**": true,
    "**/.pixi/**": true,
    "**/.venv/**": true
  },
  "search.exclude": {
    "**/external_repos/**": true,
    "**/tools/dio/**": true,
    "**/tools/google-cloud-dart/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true
  },
  "todo-tree.filtering.excludeGlobs": [
    "**/external_repos/**",
    "**/node_modules/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/dist/**",
    "**/build/**"
  ],
  "extensions.experimental.affinity": {
    "google.geminicodeassist": 1,
    "googlecloudtools.cloudcode": 1,
    "mtxr.sqltools": 2
  },
  "telemetry.telemetryLevel": "off",
  "python.formatting.provider": "none",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "omnisharp.dotnetPath": "/usr/local/share/dotnet"
}