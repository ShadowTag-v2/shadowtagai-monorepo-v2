{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "editor.formatOnSave": true,

  "files.exclude": {
    "**/archive/**": true,
    "**/node_modules/**": true,
    "**/.venv/**": true,
    "**/.venv-*/**": true,
    "**/control/**": true,
    "**/external_sdks/**": true,
    "**/external_repos/**": true,
    "**/uvicorn/**": true,
    "**/*.proto": true,
    "**/build/**": true,
    "**/third_party/**": true,
    "**/reference_architectures/**": true,
    "**/tools/google-cloud-dart/**": true,
    "**/tools/dio/**": true,
    "**/tools/java-firestore/**": true,
    "**/tools/Mole/**": true,
    "**/tools/PureMac/**": true,
    "**/.chroma_db/**": true,
    "**/.lancedb/**": true,
    "**/.lancedb_vault/**": true,
    "**/.gitnexus/**": true,
    "**/.uv-cache/**": true,
    "**/.mypy_cache/**": true,
    "**/.pytest_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/bazel-*/**": true,
    "**/playwright-report/**": true,
    "**/test-results/**": true,
    "**/.eclipse/**": true,
    "**/.kit_cache/**": true,
    "**/.stitch-sdk/**": true,
    "**/.gptram/**": true,
    "**/.semgrep/**": true,
    "**/.cloud-workstations/**": true,
    "**/.benchmarks/**": true
  },

  "search.exclude": {
    "**/archive/**": true,
    "**/node_modules/**": true,
    "**/.venv/**": true,
    "**/.venv-*/**": true,
    "**/control/**": true,
    "**/external_sdks/**": true,
    "**/external_repos/**": true,
    "**/build/**": true,
    "**/third_party/**": true,
    "**/reference_architectures/**": true,
    "**/tools/google-cloud-dart/**": true,
    "**/tools/dio/**": true,
    "**/tools/java-firestore/**": true,
    "**/.chroma_db/**": true,
    "**/.lancedb/**": true,
    "**/.gitnexus/**": true,
    "**/.uv-cache/**": true,
    "**/bazel-*/**": true,
    "**/playwright-report/**": true,
    "**/test-results/**": true
  },

  "python.analysis.exclude": [
    "**/archive",
    "**/node_modules",
    "**/external_repos",
    "**/external_sdks",
    "**/control",
    "**/uvicorn",
    "**/.venv*",
    "**/bazel-*",
    "**/build",
    "**/third_party",
    "**/reference_architectures",
    "**/tools/google-cloud-dart",
    "**/tools/dio"
  ],

  "python.testing.autoTestDiscoverOnSaveEnabled": false,
  "python.languageServer": "None",
  "[python]": {
    "editor.defaultFormatter": "astral-sh.ruff"
  },

  "java.server.launchMode": "LightWeight",
  "java.autobuild.enabled": false,
  "java.completion.enabled": false,
  "java.project.importOnFirstTimeStartup": "disabled",
  "java.import.generatesSources": false,
  "java.import.exclusions": [
    "**/*.proto",
    "**/node_modules/**",
    "**/external_repos/**",
    "**/external_sdks/**",
    "**/control/legacy_workspaces/**",
    "**/apps/devrel-demos/**",
    "**/archive/**",
    "**/build/**",
    "**/third_party/**",
    "**/reference_architectures/**",
    "**/tools/java-firestore/**",
    "**/tools/google-cloud-dart/**"
  ],

  "dart.analysisExcludedFolders": [
    "archive",
    "external_repos",
    "external_sdks",
    "build",
    "third_party",
    "reference_architectures",
    "control",
    "tools/google-cloud-dart",
    "tools/dio",
    "tools/Mole",
    "tools/PureMac",
    "node_modules"
  ],

  "bazel.enableCodeLens": false,
  "bazel.disableUpdateCheck": true,
  "gradle.autoDetect": "off",

  "antigravity.dangerMode": "auto",
  "cmake.sourceDirectory": "/Users/pikeymickey/.gemini/antigravity/Monorepo-Uphillsnowball/control/legacy_workspaces/vllm",
  "git.detectSubmodulesLimit": 20,

  "workbench.trustedDomains.promptInTrustedWorkspace": true,
  "workbench.externalUriOpeners": {
    "accounts.google.com": "default"
  },
  "trusted.domains": [
    "https://accounts.google.com",
    "https://*.google.com",
    "https://*.googleapis.com",
    "https://*.firebaseapp.com",
    "https://*.web.app",
    "https://github.com",
    "https://*.github.com",
    "https://kovelai.com",
    "https://shadowtagai.com",
    "https://pagespeed.web.dev",
    "https://notebooklm.google.com"
  ]
}
