{
  "mcpServers": {
    "firestore": {
      "command": "sh",
      "args": [
        "-lc",
        "exec npx -y @google-cloud/mcp-toolbox --prebuilt firestore"
      ]
    },
    "java_sdk": {
      "command": "sh",
      "args": [
        "-lc",
        "test -n \"$MCP_JAVA_SDK_JAR_PATH\" && test -r \"$MCP_JAVA_SDK_JAR_PATH\" && exec java -jar \"$MCP_JAVA_SDK_JAR_PATH\""
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    }
  }
}
