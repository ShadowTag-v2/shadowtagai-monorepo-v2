package main

// Uphill Snowball — Cor-Go PEP (Policy Enforcement Point) + Kinetic Outcome Billing
//
// This is the Zero Trust gateway. Every agent output stops here.
// Judge 6.1 evaluates. ScholarEval verifies. Stripe meters the outcome.
//
// Architecture:
//   Client → Cloud Run (this) → Temporal.io → ScholarEval → PACER API
//                                  ↓ KICKBACK
//                              Stripe Meter Event (Kinetic Outcome Tax)
//
// INVARIANT: No hardcoded secrets. All keys from environment variables.

import (
	"context"
	"encoding/json"
	"log"
	"net/http"
	"os"
	"strings"

	"github.com/stripe/stripe-go/v81"
	"github.com/stripe/stripe-go/v81/billing/meterevent"
	"go.temporal.io/sdk/client"
)

// KineticOutcomeFee maps outcome types to their dollar values.
// This is the anti-SaaS pricing model. We tax the disaster we prevent.
var KineticOutcomeFee = map[string]float64{
	"COMPLIANCE_BREACH_MITIGATED": 500.00,
	"LEGAL_HALLUCINATION_AVERTED": 1000.00, // The S&C Rescue Tax
	"SAAS_WORKFLOW_AUTOMATED":     150.00,
}

// chargeForOutcome fires a Stripe Meter Event for Kinetic Outcome Pricing.
// We don't charge per seat. We charge per averted disaster.
func chargeForOutcome(tenantID string, outcomeType string) {
	fee, exists := KineticOutcomeFee[outcomeType]
	if !exists {
		log.Printf("⚠️ Unknown outcome type: %s", outcomeType)
		return
	}

	_, err := meterevent.New(&stripe.BillingMeterEventParams{
		EventName: stripe.String("uphill_snowball_outcome"),
		Payload: &map[string]string{
			"stripe_customer_id": tenantID,
			"value":              "1",
		},
	})
	if err != nil {
		log.Printf("❌ Stripe meter event failed for %s: %v", tenantID, err)
		return
	}
	log.Printf("💸 WET FLEECE: Billed %s $%.2f for Outcome: %s", tenantID, fee, outcomeType)
}

// evaluateRisk performs AST-level pre-crime scanning on agent payloads.
// This is the first gate. If the payload contains injection patterns,
// we issue an RKILL before it ever reaches the Temporal workflow.
func evaluateRisk(payload string) string {
	text := strings.ToUpper(payload)
	dangerPatterns := []string{
		"DROP TABLE", "EXFILTRATE", "DELETE FROM",
		"EXEC(", "UNION SELECT", "OR 1=1",
	}
	for _, pattern := range dangerPatterns {
		if strings.Contains(text, pattern) {
			return "RKILL"
		}
	}
	return "CLEARED"
}

// pepMiddleware is the Zero Trust Policy Enforcement Point.
// Every request stops here. Risk is evaluated. Temporal workflow is dispatched.
func pepMiddleware(w http.ResponseWriter, r *http.Request) {
	var req map[string]interface{}
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		http.Error(w, `{"error": "invalid_request"}`, http.StatusBadRequest)
		return
	}

	payload, ok := req["payload"].(string)
	if !ok {
		http.Error(w, `{"error": "missing_payload"}`, http.StatusBadRequest)
		return
	}

	// Gate 1: AST-level Pre-Crime Scan
	if evaluateRisk(payload) == "RKILL" {
		w.Header().Set("Content-Type", "application/json")
		w.WriteHeader(http.StatusLocked) // 423 Locked
		w.Write([]byte(`{"status": "RKILL", "reason": "injection_pattern_detected"}`))
		return
	}

	// Gate 2: Dispatch to Temporal.io for durable execution
	temporalHost := os.Getenv("TEMPORAL_HOST")
	if temporalHost == "" {
		temporalHost = "localhost:7233"
	}

	tc, err := client.Dial(client.Options{HostPort: temporalHost})
	if err != nil {
		log.Printf("❌ Temporal dial failed: %v", err)
		http.Error(w, `{"error": "temporal_unavailable"}`, http.StatusServiceUnavailable)
		return
	}
	defer tc.Close()

	hash, _ := req["hash"].(string)
	workflowID := "UPHILL_SNOWBALL_OPS_" + hash

	_, err = tc.ExecuteWorkflow(context.Background(), client.StartWorkflowOptions{
		ID:        workflowID,
		TaskQueue: "UPHILL_JTF_QUEUE",
	}, "UphillSnowballCampaign", req)

	if err != nil {
		log.Printf("❌ Workflow dispatch failed: %v", err)
		http.Error(w, `{"error": "workflow_dispatch_failed"}`, http.StatusInternalServerError)
		return
	}

	w.Header().Set("Content-Type", "application/json")
	w.WriteHeader(http.StatusAccepted)
	json.NewEncoder(w).Encode(map[string]string{
		"status":      "DISPATCHED",
		"workflow_id": workflowID,
	})
}

func main() {
	// INVARIANT: Stripe key from environment. Never hardcoded.
	stripe.Key = os.Getenv("STRIPE_SECRET_KEY")
	if stripe.Key == "" {
		log.Fatal("FATAL: STRIPE_SECRET_KEY not set. Secrets Manager doctrine violated.")
	}

	port := os.Getenv("PORT")
	if port == "" {
		port = "8080"
	}

	http.HandleFunc("/api/v5/zta/evaluate", pepMiddleware)
	log.Printf("🚀 Uphill Snowball Cor-Go PEP online at :%s", port)
	log.Fatal(http.ListenAndServe(":"+port, nil))
}
