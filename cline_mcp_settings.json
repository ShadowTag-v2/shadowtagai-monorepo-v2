{
  "mcpServers": {
    "uphill-design-mcp": {
      "url": "https://design.googleapis.com/mcp",
      "transport": "streamable-http",
      "headers": {
        "Accept": "text/event-stream, application/json",
        "Content-Type": "application/json"
      },
      "disabled": false,
      "autoApprove": [
        "generate_color_scheme",
        "search_icons",
        "icons_instructions",
        "search_fonts",
        "describe_font"
      ],
      "note": "Google Design MCP — Material Design headless engine. No API key required. V17: unchanged (remote HTTP, not runtime-dependent)."
    },
    "uphill-gcloud-infra": {
      "command": "bunx",
      "args": ["--bun", "@google-cloud/gcloud-mcp@latest"],
      "env": {
        "GOOGLE_CLOUD_PROJECT": "shadowtag-omega-v4",
        "NODE_OPTIONS": "--dns-result-order=ipv4first",
        "HTTP_PROXY": "",
        "HTTPS_PROXY": ""
      },
      "transport": "stdio",
      "disabled": false,
      "autoApprove": ["run_gcloud_command"],
      "note": "V17: Migrated npx→bunx. Unified GCP control plane — Resource Manager, Spanner DDL/DML, Pub/Sub, Cloud Run, Billing, Datastream."
    },
    "uphill-observability": {
      "command": "bunx",
      "args": ["--bun", "@google-cloud/observability-mcp@latest"],
      "env": {
        "GOOGLE_CLOUD_PROJECT": "shadowtag-omega-v4",
        "NODE_OPTIONS": "--dns-result-order=ipv4first",
        "HTTP_PROXY": "",
        "HTTPS_PROXY": ""
      },
      "transport": "stdio",
      "disabled": false,
      "autoApprove": [
        "list_log_entries",
        "list_log_names",
        "list_sinks",
        "list_log_scopes",
        "list_metric_descriptors",
        "list_time_series",
        "list_alert_policies",
        "list_traces",
        "get_trace",
        "list_group_stats"
      ],
      "note": "V17: Migrated npx→bunx. Cloud Logging + Monitoring + Tracing."
    },
    "uphill-cloud-run": {
      "command": "bunx",
      "args": ["--bun", "@google-cloud/cloud-run-mcp@latest"],
      "env": {
        "GOOGLE_CLOUD_PROJECT": "shadowtag-omega-v4",
        "NODE_OPTIONS": "--dns-result-order=ipv4first",
        "HTTP_PROXY": "",
        "HTTPS_PROXY": ""
      },
      "transport": "stdio",
      "disabled": false,
      "autoApprove": [
        "list-services",
        "get-service",
        "get-service-log",
        "list-projects"
      ],
      "note": "V17: Migrated npx→bunx. Cloud Run compute plane."
    },
    "uphill-storage-cdn": {
      "command": "bunx",
      "args": ["--bun", "@google-cloud/storage-mcp@latest"],
      "env": {
        "GOOGLE_CLOUD_PROJECT": "shadowtag-omega-v4",
        "NODE_OPTIONS": "--dns-result-order=ipv4first",
        "HTTP_PROXY": "",
        "HTTPS_PROXY": ""
      },
      "transport": "stdio",
      "disabled": false,
      "autoApprove": [
        "list_buckets",
        "list_objects",
        "read_object_metadata",
        "read_object_content",
        "get_bucket_metadata",
        "get_bucket_location"
      ],
      "note": "V17: Migrated npx→bunx. Edge Delivery — Cloud Storage + CDN asset management."
    },
    "uphill-epistemic-memory": {
      "command": "bun",
      "args": ["./tools/mcp-gemini-memory/index.js"],
      "env": {
        "NODE_OPTIONS": "--dns-result-order=ipv4first",
        "HTTP_PROXY": "",
        "HTTPS_PROXY": ""
      },
      "transport": "stdio",
      "disabled": false,
      "autoApprove": [
        "list_memory_stores",
        "list_memory_documents",
        "search_memory"
      ],
      "note": "V17: Migrated node→bun. Prefrontal Cortex — Gemini API File Search for internal docs."
    },
    "uphill-cognitive-telemetry": {
      "command": "bunx",
      "args": ["--bun", "genkitx-mcp@latest"],
      "env": {
        "GOOGLE_CLOUD_PROJECT": "shadowtag-omega-v4",
        "NODE_OPTIONS": "--dns-result-order=ipv4first",
        "HTTP_PROXY": "",
        "HTTPS_PROXY": ""
      },
      "transport": "stdio",
      "disabled": true,
      "autoApprove": [],
      "note": "V17: Migrated npx→bunx. Genkit OpenTelemetry. Disabled until Genkit flows are authored."
    },
    "uphill-economic-engine": {
      "command": "bunx",
      "args": ["--bun", "@stripe/agent-toolkit@latest"],
      "env": {
        "NODE_OPTIONS": "--dns-result-order=ipv4first",
        "HTTP_PROXY": "",
        "HTTPS_PROXY": ""
      },
      "transport": "stdio",
      "disabled": true,
      "autoApprove": [],
      "note": "V17: Migrated npx→bunx. Stripe Agent Toolkit — Payment processing. Secrets via GCP Secret Manager only."
    },
    "uphill-notebooklm": {
      "command": "bunx",
      "args": ["--bun", "notebooklm-mcp@latest"],
      "env": {
        "HEADLESS": "true",
        "NODE_OPTIONS": "--dns-result-order=ipv4first",
        "HTTP_PROXY": "",
        "HTTPS_PROXY": ""
      },
      "transport": "stdio",
      "disabled": false,
      "autoApprove": ["setup_auth", "list_notebooks", "search_notebooks", "get_notebook"],
      "note": "V17: Migrated npx→bunx. IPI Quarantine — NotebookLM zero-trust data ingestion."
    }
  }
}
