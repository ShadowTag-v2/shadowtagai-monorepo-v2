{
  "mcpServers": {
    "firebase-mcp-server": {
      "command": "bunx",
      "args": ["--bun", "@firebase/mcp-server"],
      "transport": "stdio"
    },
    "chrome-devtools-mcp": {
      "command": "bunx",
      "args": ["--bun", "@puppeteer/chrome-devtools-mcp"],
      "env": { "CHROME_DEBUG_PORT": "9222" },
      "transport": "stdio"
    },
    "google-design-mcp": {
      "command": "bunx",
      "args": ["--bun", "@google/design-mcp"],
      "env": { "DESIGN_API_ENDPOINT": "wss://design.googleapis.com/mcp" },
      "transport": "stdio"
    },
    "StitchMCP": {
      "command": "bunx",
      "args": ["--bun", "@stitch/mcp-server"],
      "transport": "stdio"
    },
    "google-developer-knowledge": {
      "command": "bunx",
      "args": ["--bun", "@googlecloud/vertex-ai-search-mcp"],
      "transport": "stdio"
    },
    "sequential-thinking": {
      "command": "bunx",
      "args": ["--bun", "@anthropic/sequential-thinking-mcp"],
      "transport": "stdio"
    },
    "jules-mcp-server": {
      "command": "bunx",
      "args": ["--bun", "@google/jules-mcp"],
      "transport": "stdio"
    },
    "os-infrastructure-matrix": {
      "command": "bunx",
      "args": ["--bun", "@google/mcp-toolbox"],
      "env": { "ENABLE_SERVICES": "resourcemanager,spanner,pubsub" },
      "transport": "stdio"
    },
    "database-insights-mcp": {
      "command": "bunx",
      "args": ["--bun", "@googlecloud/database-insights-mcp"],
      "env": { "SPANNER_PROJECT": "shadowtag-omega-v4", "SPANNER_INSTANCE": "core-cluster" },
      "transport": "stdio"
    },
    "observability": {
      "command": "bunx",
      "args": ["--bun", "@google/genkit-mcp"],
      "transport": "stdio"
    },
    "cloud-run": {
      "command": "bunx",
      "args": ["--bun", "@google/mcp-toolbox"],
      "env": { "ENABLE_SERVICES": "run" },
      "transport": "stdio"
    },
    "storage": {
      "command": "bunx",
      "args": ["--bun", "@google/mcp-toolbox"],
      "env": { "ENABLE_SERVICES": "storage" },
      "transport": "stdio"
    },
    "stripe-mcp": { "command": "bunx", "args": ["--bun", "@stripe/mcp"], "transport": "stdio" },
    "bigquery": {
      "command": "bunx",
      "args": ["--bun", "@google/mcp-toolbox"],
      "env": { "ENABLE_SERVICES": "bigquery" },
      "transport": "stdio"
    },
    "dart-language-server": {
      "command": "dart",
      "args": ["language-server", "--protocol=lsp"],
      "transport": "stdio"
    },
    "vertex-ai": {
      "command": "bunx",
      "args": ["--bun", "@google/mcp-toolbox"],
      "env": { "ENABLE_SERVICES": "aiplatform", "GOOGLE_CLOUD_PROJECT": "shadowtag-omega-v4" },
      "transport": "stdio"
    },
    "spanner": {
      "command": "bunx",
      "args": ["--bun", "@google/mcp-toolbox"],
      "env": { "ENABLE_SERVICES": "spanner", "SPANNER_PROJECT": "shadowtag-omega-v4", "SPANNER_INSTANCE": "core-cluster" },
      "transport": "stdio"
    },
    "datastream": {
      "command": "bunx",
      "args": ["--bun", "@google/mcp-toolbox"],
      "env": { "ENABLE_SERVICES": "datastream", "GOOGLE_CLOUD_PROJECT": "shadowtag-omega-v4" },
      "transport": "stdio"
    },
    "pomelli-swarm": {
      "command": "bun",
      "args": ["run", "scripts/inspect_design_quality.ts"],
      "transport": "stdio"
    }
  }
}
