# Docker ignore file for Pnkln
# Keep images minimal and secure

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv

# Testing
.pytest_cache/
.coverage
htmlcov/
*.cover

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore
.gitattributes

# Documentation (exclude from production image)
docs/
*.md
!README.md

# Node modules (if any)
node_modules/
package-lock.json

# Logs
*.log

# Environment files
.env
.env.local
.env.*.local

# Test files
tests/
test_*.py
*_test.py

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Development tools
Makefile
docker-compose.yml
docker-compose.*.yml
