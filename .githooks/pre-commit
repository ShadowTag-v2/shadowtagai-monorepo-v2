#!/bin/bash
# Pre-commit hook: GCA pruner dry-run check
# Warns if state.vscdb is over 20MB

DB_PATH="$HOME/Library/Application Support/Antigravity/User/globalStorage/state.vscdb"

if [ -f "$DB_PATH" ]; then
    SIZE_BYTES=$(stat -f%z "$DB_PATH" 2>/dev/null || stat -c%s "$DB_PATH" 2>/dev/null)
    SIZE_MB=$((SIZE_BYTES / 1024 / 1024))
    
    if [ "$SIZE_MB" -gt 20 ]; then
        echo "⚠️  WARNING: state.vscdb is ${SIZE_MB}MB (threshold: 20MB)"
        echo "   Run: python3 scripts/prune_gca_chat_threads.py --write"
        echo "   (Close IDE first with Cmd+Q)"
        echo ""
        # Warning only, don't block commits
    fi
fi

# Run ruff check on staged Python files
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$')
if [ -n "$STAGED_PY" ]; then
    python3 -m ruff check $STAGED_PY 2>/dev/null
    if [ $? -ne 0 ]; then
        echo ""
        echo "⚠️  Ruff found issues. Run: make fix"
        # Warning only for now
    fi
fi
