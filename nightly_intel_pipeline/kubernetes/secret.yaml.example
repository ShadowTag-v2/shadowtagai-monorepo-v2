# Example secret configuration
# DO NOT commit actual secrets to git
# Create this resource using kubectl with actual values

apiVersion: v1
kind: Secret
metadata:
  name: intel-pipeline-secrets
  namespace: default
  labels:
    app: nightly-intel-pipeline
type: Opaque
stringData:
  github-token: "YOUR_GITHUB_TOKEN_HERE"
  anthropic-api-key: "YOUR_ANTHROPIC_API_KEY_HERE"

---
# To create the secret with actual values, use:
# kubectl create secret generic intel-pipeline-secrets \
#   --from-literal=github-token='YOUR_GITHUB_TOKEN' \
#   --from-literal=anthropic-api-key='YOUR_ANTHROPIC_KEY' \
#   --namespace=default
