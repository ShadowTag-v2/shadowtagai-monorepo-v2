# Application Settings
APP_NAME="Claude Memory & Search Service"
APP_VERSION="1.0.0"
DEBUG=true
API_PREFIX="/api/v1"

# Server Settings
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Database Settings
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/claude_memory
# Or use SQLite for development
# DATABASE_URL=sqlite+aiosqlite:///./claude_memory.db

# Redis Settings (for caching and background tasks)
REDIS_URL=redis://localhost:6379/0

# Security Settings
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Claude API Settings
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Memory Settings
MEMORY_SYNTHESIS_INTERVAL_HOURS=24
MAX_MEMORY_ITEMS_PER_PROJECT=1000
ENABLE_AUTO_SUMMARIZATION=true
SUMMARIZATION_MIN_MESSAGES=10

# Vector Search Settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DIMENSION=384
SEARCH_TOP_K=10

# Background Tasks
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Logging
LOG_LEVEL=INFO
