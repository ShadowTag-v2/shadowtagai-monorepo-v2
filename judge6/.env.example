# Judge #6 Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME="Judge #6 - ATP 5-19 Risk Management API"
APP_VERSION="1.0.0"
ENVIRONMENT="development"  # development, staging, production
DEBUG=true

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY="your-secret-key-change-this-in-production-min-32-chars"
ALGORITHM="HS256"

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/judge6"
DATABASE_ECHO=false

# Redis
REDIS_URL="redis://localhost:6379/0"

# AI/ML API Keys
GOOGLE_API_KEY="your-google-gemini-api-key"
ANTHROPIC_API_KEY="your-anthropic-claude-api-key"  # Optional backup
OPENAI_API_KEY="your-openai-gpt-api-key"  # Optional backup

# Stripe Billing
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY="price_..."
STRIPE_PRICE_STARTER_ANNUAL="price_..."
STRIPE_PRICE_PROFESSIONAL_MONTHLY="price_..."
STRIPE_PRICE_PROFESSIONAL_ANNUAL="price_..."

# Monitoring
SENTRY_DSN=""  # Optional: Sentry error tracking
ENABLE_PROMETHEUS=true

# CORS Origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:8000,https://judgeasaservice.ai"

# Rate Limits (requests per month)
RATE_LIMIT_FREE=1000
RATE_LIMIT_STARTER=10000
RATE_LIMIT_PROFESSIONAL=100000
RATE_LIMIT_ENTERPRISE=-1  # Unlimited

# ATP 5-19 Risk Thresholds (0.0 to 1.0)
RISK_CATASTROPHIC_THRESHOLD=0.9
RISK_CRITICAL_THRESHOLD=0.7
RISK_MODERATE_THRESHOLD=0.4
RISK_LOW_THRESHOLD=0.2

# Performance
TARGET_P99_LATENCY_MS=90
MAX_CONCURRENT_REQUESTS=100
