{
  "dashboard": {
    "title": "Speculation Engine — Bridge Latency",
    "tags": ["shadowtag", "speculation-engine", "otel"],
    "timezone": "utc",
    "refresh": "30s",
    "panels": [
      {
        "title": "Bridge Call Latency (p50/p95/p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(speculation_bridge_duration_ms_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(speculation_bridge_duration_ms_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(speculation_bridge_duration_ms_bucket[5m]))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } } }
      },
      {
        "title": "Sweep Success Rate",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(speculation_bridge_calls_total{success='true'}[1h])) / sum(rate(speculation_bridge_calls_total[1h])) * 100"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [{ "value": 0, "color": "red" }, { "value": 95, "color": "green" }]
            }
          }
        }
      },
      {
        "title": "Sweeps Per Hour",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "sum(increase(speculation_bridge_calls_total{operation='research_sweep'}[1h]))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [{ "value": 0, "color": "blue" }, { "value": 4, "color": "orange" }]
            }
          }
        }
      },
      {
        "title": "Phase Speculation Duration",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "rate(speculation_phase_duration_ms_sum[5m]) / rate(speculation_phase_duration_ms_count[5m])",
            "legendFormat": "{{phase}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "ms" } }
      },
      {
        "title": "OTel Span Error Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(speculation_engine_spans_total{error='true'}[5m])) by (operation)",
            "legendFormat": "{{operation}} errors"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20 } } }
      }
    ]
  }
}
