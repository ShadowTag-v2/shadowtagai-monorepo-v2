{
  "security-enforcement": {
    "type": "guardrail",
    "enforcement": "block",
    "priority": "critical",
    "promptTriggers": {
      "keywords": [
        "auth",
        "authenticate",
        "authorization",
        "encrypt",
        "encryption",
        "decrypt",
        "secret",
        "password",
        "token",
        "apiKey",
        "api",
        "endpoint",
        "deploy",
        "production",
        "database",
        "db",
        "prisma",
        "query"
      ],
      "intentPatterns": [
        "(create|add|implement|build).*(auth|security|api|endpoint)",
        "(deploy|ship|release|production)",
        "store.*(password|secret|key)",
        "connect.*(database|db|api)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/*.ts",
        "**/*.py",
        "**/*.js",
        "**/auth/**/*",
        "**/api/**/*",
        "**/.env*",
        "**/config/**/*"
      ],
      "contentPatterns": [
        "password",
        "apiKey",
        "SECRET",
        "secret",
        "token",
        "encrypt",
        "decrypt",
        "http://",
        "prisma",
        "fetch\\(",
        "axios"
      ]
    }
  },

  "ShadowTag-v2jr-judge": {
    "type": "decision",
    "enforcement": "suggest",
