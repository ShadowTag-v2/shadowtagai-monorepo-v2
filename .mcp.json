{
  "mcpServers": {
    "zt-legal": {
      "type": "http",
      "url": "http://localhost:8000/mcp",
      "description": "ZT.1 Zero-Touch Legal Deadline Management — ingest filings, review AI-drafted deadlines, approve to master docket",
      "tools": [
        {
          "name": "zt_ingest",
          "description": "Ingest a raw legal filing and extract deadlines for human review",
          "endpoint": "POST /api/v1/rules/matters/{matter_id}/ingest",
          "inputSchema": {
            "type": "object",
            "properties": {
              "matter_id": { "type": "string", "format": "uuid" },
              "tenant_id": { "type": "string", "format": "uuid" },
              "raw_text": { "type": "string" },
              "source": { "type": "string", "enum": ["email_webhook", "manual_upload", "api"] },
              "jurisdiction": { "type": "string", "default": "FRCP" },
              "trigger_date": { "type": "string", "format": "date" }
            },
            "required": ["matter_id", "tenant_id", "raw_text", "source", "trigger_date"]
          }
        },
        {
          "name": "zt_queue",
          "description": "List AI-drafted deadlines pending attorney approval for a matter",
          "endpoint": "GET /api/v1/rules/matters/{matter_id}/queue",
          "inputSchema": {
            "type": "object",
            "properties": {
              "matter_id": { "type": "string", "format": "uuid" },
              "include_status": { "type": "string", "default": "pending_approval" }
            },
            "required": ["matter_id"]
          }
        },
        {
          "name": "zt_approve",
          "description": "Attorney approves AI-drafted deadline — commits to master docket",
          "endpoint": "POST /api/v1/rules/extractions/{extraction_id}/approve",
          "inputSchema": {
            "type": "object",
            "properties": {
              "extraction_id": { "type": "string", "format": "uuid" },
              "approver_id": { "type": "string", "format": "uuid" },
              "notes": { "type": "string" }
            },
            "required": ["extraction_id", "approver_id"]
          }
        },
        {
          "name": "zt_docket",
          "description": "Retrieve the approved master docket for a matter, sorted by due date",
          "endpoint": "GET /api/v1/rules/matters/{matter_id}/docket",
          "inputSchema": {
            "type": "object",
            "properties": {
              "matter_id": { "type": "string", "format": "uuid" }
            },
            "required": ["matter_id"]
          }
        }
      ]
    },
    "aiyou-rag": {
      "type": "http",
      "url": "http://localhost:8000/mcp",
      "description": "AiYou RAG graph — insert artifacts and query the sovereign knowledge base",
      "tools": [
        {
          "name": "aiyou_query",
          "description": "Query the AiYou sovereign knowledge base via semantic RAG",
          "endpoint": "POST /api/v1/aiyou/agent/query",
          "inputSchema": {
            "type": "object",
            "properties": {
              "q": { "type": "string", "description": "Natural language query" }
            },
            "required": ["q"]
          }
        },
        {
          "name": "aiyou_ingest",
          "description": "Insert a document chunk into the AiYou RAG graph",
          "endpoint": "POST /api/v1/aiyou/graph/insert",
          "inputSchema": {
            "type": "object",
            "properties": {
              "artifactId": { "type": "string" },
              "text": { "type": "string" },
              "tags": { "type": "object" },
              "embed": { "type": "array", "items": { "type": "number" } }
            },
            "required": ["artifactId", "text", "embed"]
          }
        }
      ]
    },
    "alphaxiv": {
      "type": "sse",
      "url": "https://api.alphaxiv.org/mcp/v1",
      "description": "alphaXiv — semantic search and structured retrieval across the full arXiv corpus (2M+ papers). Tools: embedding_similarity_search, full_text_papers_search, agentic_paper_retrieval, get_paper_content, answer_pdf_queries, read_files_from_github_repository",
      "headers": {
        "Authorization": "Bearer ${ALPHAXIV_API_KEY}"
      }
    },
    "gitnexus": {
      "type": "stdio",
      "command": "gitnexus",
      "args": ["mcp"],
      "description": "GitNexus — codebase knowledge graph with 7 tools: query (BM25+semantic), context (360° symbol references), impact (blast radius), detect_changes (git-diff mapping), rename, cypher, list_repos",
      "env": {
        "NEXUS_ROOT": "${workspaceFolder}"
      }
    }
  }
}
