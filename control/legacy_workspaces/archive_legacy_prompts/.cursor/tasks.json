{
  "version": "1.0",
  "tasks": [
    {
      "name": "aiyou-autofix-staged",
      "description": "Tests → staged fixes (gpt-5-fast) → refine (claude-4-sonnet) → escalate (gpt-5) → auto-commit",
      "trigger": "manual",
      "env": { "stream": false },
      "steps": [
        {
          "id": "t1",
          "action": "runTests",
          "args": { "framework": "pytest", "coverageThreshold": 0.95 }
        },
        {
          "id": "f1",
          "if": "steps.t1.failed",
          "action": "fixErrors",
          "args": {
            "model": "gpt-5-fast",
            "scope": "staged",
            "strategy": "minimal-diff",
            "maxAttempts": 1,
            "includeUnstaged": false,
        "stream": false,
        "maxTokens": 2048
          }
        },
        {
          "id": "t2",
          "if": "steps.f1.applied || steps.t1.failed",
          "action": "runTests",
          "args": { "framework": "pytest", "coverageThreshold": 0.95 }
        },
        {
          "id": "r1",
          "if": "steps.t2.failed",
          "action": "refineDiff",
          "args": {
            "model": "claude-4-sonnet",
            "scope": "staged",
            "strategy": "surgical-refactor",
            "maxTokens": 1200,
            "stream": false
          }
        },
        {
          "id": "t3",
          "if": "steps.r1.applied",
          "action": "runTests",
          "args": { "framework": "pytest", "coverageThreshold": 0.95 }
        },
        {
          "id": "f2",
          "if": "steps.t3.failed || (steps.t2.failed && !steps.r1.applied)",
          "action": "fixErrors",
          "args": {
            "model": "gpt-5",
            "scope": "changed",
            "strategy": "minimal-diff",
            "maxAttempts": 2,
            "maxTokens": 2048,
            "stream": false,
            "fallback": {
              "model": "gpt-5-fast",
              "maxTokens": 2048
            }
          }
        },
        {
          "id": "t4",
          "if": "steps.f2.applied",
          "action": "runTests",
          "args": { "framework": "pytest", "coverageThreshold": 0.95 }
        },
        {
          "id": "f3",
          "if": "steps.t4.failed",
          "action": "fixErrors",
          "args": {
            "model": "gpt-5",
            "scope": "project",
            "strategy": "minimal-diff",
            "maxAttempts": 1,
            "maxTokens": 2048,
            "stream": false,
            "fallback": {
              "model": "claude-4-sonnet",
              "maxTokens": 1200
            }
          }
        },
        {
          "id": "t5",
          "if": "steps.f3.applied",
          "action": "runTests",
          "args": { "framework": "pytest", "coverageThreshold": 0.95 }
        },
        {
          "id": "commit",
          "if": "steps.t5.passed || steps.t4.passed || steps.t3.passed || steps.t2.passed || steps.t1.passed",
          "action": "commit",
          "args": {
            "message": "autofix: tests green (staged-first pipeline: gpt-5-fast → claude-4-sonnet → gpt-5)",
            "autoApprove": true
          }
        }
      ]
    },
    {
      "name": "aiyou-autofix-staged (manual)",
      "description": "Manual trigger of the staged-first pipeline",
      "trigger": "manual",
      "inheritFrom": "aiyou-autofix-staged"
    },
    {
      "name": "aiyou-status-check",
      "description": "Print which scope each step uses",
      "trigger": "manual",
      "steps": [
        { "id": "echo1", "action": "echo", "args": { "message": "Step f1 → gpt-5-fast scope: staged" } },
        { "id": "echo2", "action": "echo", "args": { "message": "Step r1 → claude-4-sonnet scope: staged" } },
        { "id": "echo3", "action": "echo", "args": { "message": "Step f2 → gpt-5 scope: changed" } },
        { "id": "echo4", "action": "echo", "args": { "message": "Step f3 → gpt-5 scope: project" } }
      ]
    }
  ]
}
{
  "version": "0.1",
  "tasks": [
    {
      "label": "AiYou Auto-Repair on Save",
      "type": "shell",
      "command": "python",
      "args": ["tools/aiyou_cto_auto.py"],
      "options": {
        "env": {
          "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}",
          "OPENAI_API_KEY": "${env:OPENAI_API_KEY}",
          "AIYOU_FIX_ATTEMPTS": "${env:AIYOU_FIX_ATTEMPTS}"
        }
      },
      "problemMatcher": [
        {
          "owner": "aiyou",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "pattern": [
            {
              "regexp": "^(.*?):(\\d+):(\\d+): (error|warning) (.*)$",
              "file": 1,
              "line": 2,
              "column": 3,
              "severity": 4,
              "message": 5
            }
          ]
        }
      ],
      "group": "build",
      "isBackground": false,
      "runOptions": { "runOn": "save" }
    },
    {
      "label": "AiYou Full Scan",
      "type": "shell",
      "command": "python",
      "args": ["tools/aiyou_cto_auto.py"],
      "options": {
        "env": {
          "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}",
          "OPENAI_API_KEY": "${env:OPENAI_API_KEY}",
          "AIYOU_FIX_ATTEMPTS": "${env:AIYOU_FIX_ATTEMPTS}"
        }
      },
      "group": "build",
      "isBackground": false
    },
    {
      "label": "Hardhat Compile",
      "type": "shell",
      "command": "npx",
      "args": ["hardhat", "compile"],
      "group": "build",
      "isBackground": false
    },
    {
      "label": "Hardhat Deploy Local",
      "type": "shell",
      "command": "npx",
      "args": ["hardhat", "run", "scripts/deploygpt4.ts"],
      "group": "build",
      "isBackground": false
    },
    {
      "label": "Hardhat Deploy Sepolia",
      "type": "shell",
      "command": "npx",
      "args": ["hardhat", "run", "scripts/deploygpt4.ts", "--network", "sepolia"],
      "group": "build",
      "isBackground": false
    }
  ]
}
