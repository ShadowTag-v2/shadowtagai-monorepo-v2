{
  "name": "Claude Code Development Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // Configure container features
  "features": {},

  // Use 'forwardPorts' to make a list of ports inside the container available locally
  "forwardPorts": [],

  // Configure tool-specific properties
  "customizations": {
    "vscode": {
      "extensions": [
        // Essential extensions
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-python.python",
        "ms-python.vscode-pylance",

        // Git and collaboration
        "eamodio.gitlens",

        // Documentation and markdown
        "yzhang.markdown-all-in-one",

        // Code quality
        "streetsidesoftware.code-spell-checker"
      ],

      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[python]": {
          "editor.defaultFormatter": "ms-python.python",
          "editor.formatOnSave": true
        },
        "files.exclude": {
          "**/node_modules": true,
          "**/__pycache__": true,
          "**/.pytest_cache": true
        }
      }
    }
  },

  // Mount volumes for persistence
  "mounts": [
    // Persist command history
    "source=devcontainer-zsh-history,target=/commandhistory,type=volume",
    // Persist npm cache
    "source=devcontainer-npm-cache,target=/root/.npm,type=volume",
    // Persist pip cache
    "source=devcontainer-pip-cache,target=/root/.cache/pip,type=volume"
  ],

  // Run commands after the container is created
  "postCreateCommand": "npm install",

  // Initialize firewall on container start
  "postStartCommand": "bash /usr/local/bin/init-firewall.sh",

  // Use 'postAttachCommand' to run commands after attaching to the container
  "postAttachCommand": {
    "server": "echo 'Development container is ready!'"
  },

  // Set environment variables
  "remoteEnv": {
    "HISTFILE": "/commandhistory/.zsh_history"
  },

  // Run as root to allow firewall configuration
  "remoteUser": "root",

  // Add security options
  "runArgs": ["--cap-add=NET_ADMIN", "--security-opt=seccomp=unconfined"]
}
