steps:
  - name: 'gcr.io/cloud-builders/docker'
    args: ['build', '-t', 'gcr.io/$PROJECT_ID/shadowtagai:$COMMIT_SHA', '.']
  - name: 'gcr.io/google.com/cloudsdktool/cloud-sdk'
    args:
    - run
    - deploy
    - shadowtagai
    - --image=gcr.io/$PROJECT_ID/shadowtagai:$COMMIT_SHA
    - --region=us-central1
    - --platform=managed
    - --allow-unauthenticated
    - --set-env-vars=REDIS_URL=$REDIS_URL,GITHUB_TOKEN=$GITHUB_TOKEN
options:
  logging: CLOUD_LOGGING_ONLY
