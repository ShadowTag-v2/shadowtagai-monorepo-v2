{
  "name": "mcp-filesystem-tools-sandbox",
  "version": "1.0.0",
  "description": "Execution sandbox configuration for MCP filesystem-based tool discovery",
  "runtime": {
    "type": "nodejs",
    "version": "20.x",
    "allowedModules": ["fs/promises", "path", "crypto", "util", "stream", "buffer"]
  },
  "security": {
    "sandboxed": true,
    "networkAccess": {
      "enabled": true,
      "allowedHosts": [
        "*.googleapis.com",
        "*.anthropic.com",
        "*.polygon.technology",
        "*.ethereum.org",
        "*.arweave.net"
      ],
      "maxConcurrentConnections": 50
    },
    "filesystem": {
      "enabled": true,
      "allowedPaths": ["./workspace", "./servers", "./skills", "./examples"],
      "readOnly": ["./servers", "./skills", "./examples"],
      "readWrite": ["./workspace"],
      "maxFileSize": "100MB"
    },
    "resourceLimits": {
      "maxMemory": "2GB",
      "maxCPU": "80%",
      "maxExecutionTime": "600s",
      "maxProcesses": 10
    }
  },
  "environment": {
    "variables": {
      "NODE_ENV": "production",
      "MCP_MODE": "filesystem",
      "WORKSPACE_DIR": "./workspace"
    },
    "secrets": [
      "VERTEX_AI_API_KEY",
      "ANTHROPIC_API_KEY",
      "ETHEREUM_PRIVATE_KEY",
      "POLYGON_PRIVATE_KEY"
    ]
  },
  "monitoring": {
    "enabled": true,
    "logLevel": "info",
    "metrics": ["tokenUsage", "executionTime", "memoryUsage", "apiCalls"],
    "alerts": {
      "highMemoryUsage": {
        "threshold": "1.8GB",
        "action": "warn"
      },
      "longExecution": {
        "threshold": "300s",
        "action": "warn"
      }
    }
  },
  "privacy": {
    "piiDetection": true,
    "tokenization": {
      "enabled": true,
      "fields": ["email", "phone", "ssn", "creditCard"],
      "algorithm": "aes-256-gcm"
    },
    "auditLog": true
  },
  "optimization": {
    "caching": {
      "enabled": true,
      "maxSize": "500MB",
      "ttl": "1h"
    },
    "parallelism": {
      "maxWorkers": 10,
      "queueSize": 100
    }
  }
}
