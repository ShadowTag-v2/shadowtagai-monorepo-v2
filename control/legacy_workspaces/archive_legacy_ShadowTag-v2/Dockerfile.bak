# FlyingMonkeys Server Dockerfile - Complete
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc curl \
    && rm -rf /var/lib/apt/lists/*

# Copy application code from project root to /app
COPY . /app

# Install vendored google_adk
RUN pip install /app/src/vendor/google_adk

# Re-install dependencies to ensure no conflicts (optional but safe)
# Install Python dependencies for flyingmonkeys
RUN pip install --no-cache-dir \
    aiohttp \
    fastapi \
    google-cloud-aiplatform \
    google-cloud-pubsub \
    google-generativeai \
    httpx \
    pydantic \
    redis \
    uvicorn[standard] \
    vertexai

# Copy the entire project structure needed by flyingmonkeys-server
COPY bin/flyingmonkeys-server /app/bin/flyingmonkeys-server
COPY agents/ /app/agents/
COPY src/ /app/src/
# Include vendored "Found Business Assets"
COPY src/vendor /app/src/vendor
COPY prompts/ /app/prompts/

# Set PYTHONPATH for imports
ENV PYTHONPATH=/app

# Expose port (Cloud Run uses PORT env var, default 8080)
EXPOSE 8080

# Run the server
CMD ["python", "/app/bin/flyingmonkeys-server"]
