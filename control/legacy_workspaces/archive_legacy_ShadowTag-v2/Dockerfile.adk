FROM python:3.11-slim

WORKDIR /app

# Install dependencies required by ADK
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt uvicorn fastapi google-adk

# Copy project files
COPY src/ src/
COPY libs/ libs/

# Set Python path to include source directories
ENV PYTHONPATH=/app

# Expose port (Cloud Run defaults to 8080)
EXPOSE 8080

# Command to run the application
CMD ["uvicorn", "src.api.adk_main:app", "--host", "0.0.0.0", "--port", "8080"]
