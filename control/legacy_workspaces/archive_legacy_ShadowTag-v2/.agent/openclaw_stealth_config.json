{
  "safe_mode": "STRICT",
  "max_apm": 120,
  "mouse_movement": {
    "type": "bezier",
    "speed_variance_min": 0.8,
    "speed_variance_max": 1.5
  },
  "keyboard": {
    "base_delay_ms": 45,
    "jitter_ms": 25,
    "typo_correction_rate": 0.03
  },
  "allowed_bounds": { "x_min": 0, "y_min": 0, "x_max": 1920, "y_max": 1080 },
  "blocked_processes": ["antigravity_billing", "system_auth"],
  "block_unsafe_sys_calls": true
}
