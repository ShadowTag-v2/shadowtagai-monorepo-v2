        "threshold": 0.05,
        "classes_to_block": ["sexual_activity", "sexual_attire", "suggestive", "nsfw_cartoon"]
      },
      "visual_context_check": {
        "enabled": true,
        "note": "Blocks terms like 'bikini', 'floss', 'lingerie' if a real person is named."
      }
    },
    "dynamic_kill_switch": {
      "description": "The 'Retaliation Loop' Breaker. Updates instantly without model retraining.",
      "blocked_entities": ["ashley st. clair", "taylor swift", "elon musk"],
      "blocked_phrases": [
        "bikini made of floss",
        "age regression",
        "as a 14 year old",
        "high school photo"
      ]
    }
  }
}
