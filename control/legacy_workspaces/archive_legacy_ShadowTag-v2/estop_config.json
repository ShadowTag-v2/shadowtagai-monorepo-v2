{
  "policy_version": "2026-01-18-HOTFIX",
  "estop_mode": "STRICT_BLOCK",
  "client_firewall_rules": {
    "google_model_armor": {
      "template_id": "block-unsafe-prompts-v2",
      "pii_filter": {
        "enabled": true,
        "action": "BLOCK",
        "entity_types": ["PERSON", "PHONE_NUMBER", "EMAIL"]
      },
      "jailbreak_detection": {
        "enabled": true,
        "action": "ESTOP"
      }
    },
    "hive_moderation": {
