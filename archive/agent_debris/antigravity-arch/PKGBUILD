# Maintainer: SHADOWTAGAI Core Stack Team <team@shadowtagai.ai>
# PKGBUILD for SHADOWTAGAI Antigravity Service

pkgname=shadowtagai-antigravity
pkgver=0.1.0
pkgrel=1
pkgdesc="SHADOWTAGAI Kernel Chain - ATP 5-19 Decision Governance Service"
arch=('x86_64')
url="https://github.com/ehanc69/aiyou-fastapi-services"
license=('custom:Proprietary')
depends=(
    'python>=3.11'
    'python-pip'
    'python-virtualenv'
)
makedepends=('git')
backup=('etc/shadowtagai/config.env')
install=shadowtagai.install
source=(
    "git+${url}.git#tag=v${pkgver}"
    "shadowtagai.service"
    "shadowtagai.sysusers"
    "shadowtagai.tmpfiles"
)
sha256sums=(
    'SKIP'
    'SKIP'
    'SKIP'
    'SKIP'
)

prepare() {
    cd "${srcdir}/aiyou-fastapi-services"
    # Any patching would go here
}

build() {
    cd "${srcdir}/aiyou-fastapi-services"
    # Create virtualenv in build dir
    python -m venv "${srcdir}/venv"
    "${srcdir}/venv/bin/pip" install --upgrade pip wheel
    "${srcdir}/venv/bin/pip" install -r requirements.txt
    "${srcdir}/venv/bin/pip" install .
}

package() {
    cd "${srcdir}/aiyou-fastapi-services"

    # Install application to /opt/shadowtagai
    install -d "${pkgdir}/opt/shadowtagai"

    # Copy virtualenv
    cp -a "${srcdir}/venv" "${pkgdir}/opt/shadowtagai/"

    # Copy application code
    cp -r app "${pkgdir}/opt/shadowtagai/"
    cp -r shadowtagai "${pkgdir}/opt/shadowtagai/"
    cp -r src "${pkgdir}/opt/shadowtagai/"
    cp requirements.txt "${pkgdir}/opt/shadowtagai/"
    cp pyproject.toml "${pkgdir}/opt/shadowtagai/"

    # Fix virtualenv paths (they're hardcoded during creation)
    sed -i "s|${srcdir}/venv|/opt/shadowtagai/venv|g" \
        "${pkgdir}/opt/shadowtagai/venv/bin/"* 2>/dev/null || true

    # Install systemd units
    install -Dm644 "${srcdir}/shadowtagai.service" \
        "${pkgdir}/usr/lib/systemd/system/shadowtagai.service"
    install -Dm644 "${srcdir}/shadowtagai.sysusers" \
        "${pkgdir}/usr/lib/sysusers.d/shadowtagai.conf"
    install -Dm644 "${srcdir}/shadowtagai.tmpfiles" \
        "${pkgdir}/usr/lib/tmpfiles.d/shadowtagai.conf"

    # Install config directory
    install -d "${pkgdir}/etc/shadowtagai"

    # Create example config if it doesn't exist
    cat > "${pkgdir}/etc/shadowtagai/config.env" << 'EOF'
# SHADOWTAGAI Kernel Chain Configuration
# Copy this file and customize for your environment

# Service Settings
SERVICE_NAME=shadowtagai-kernel-chain
LOG_LEVEL=INFO
ENABLE_METRICS=true

# Gemini API Configuration
GEMINI_MODEL=gemini-2.0-flash-exp
# GOOGLE_API_KEY=your-api-key-here

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Security
# SECRET_KEY=generate-a-secure-key
EOF
    chmod 600 "${pkgdir}/etc/shadowtagai/config.env"

    # Create log directory marker
    install -d "${pkgdir}/var/log/shadowtagai"
}
