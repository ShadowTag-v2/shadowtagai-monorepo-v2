+    "scripts/inject_antigravity_doctrine.sh"
+    "tools/dev-environment/claude-code-config/packages/website/next.config.js"
+    "vertex-ai-samples"
+    "scripts/deploy_swarm_enhancements.py"
+    "scripts/generic_ingest.py"
+    "scripts/ingest_local.sh"
+    "Legacy_Archives"
+    "data/imported_phase_docs"
+)
+
+for path in "${FORCE_PATHS[@]}"; do
+    if [ -e "$path" ]; then
+        echo "   -> Force adding $path"
+        git add -f "$path"
+    else
+        echo "   -> Skipping missing path: $path"
+    fi
+done
+
 # 4. Commit
 echo "💾 Committing..."
 if git diff-index --quiet HEAD --; then
     echo "✅ No changes to commit."
 else
-    git commit -m "Antigravity: Automated Git State Fix / Sync"
+    git commit -m "Antigravity: Forced Git State Fix (Included Legacy & Docs)"
     echo "✅ Changes committed."
 fi

