#!/usr/bin/env bash
# scripts/repo-oracle — Lookup-before-invention gate
# Searches the monorepo for existing implementations before creating new ones.
# Usage: scripts/repo-oracle <query> [--json]
set -uo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

if [[ $# -lt 1 ]]; then
  echo "Usage: scripts/repo-oracle <query> [--json]"
  echo "  Searches packages/, scripts/, .agents/skills/, libs/, apps/ for existing code."
  exit 1
fi

QUERY="$1"
JSON_OUTPUT=false
[[ "${2:-}" == "--json" ]] && JSON_OUTPUT=true

# Delegate to the Python oracle if available
ORACLE_PY="${REPO_ROOT}/packages/repo_oracle/oracle.py"
if [[ -f "$ORACLE_PY" ]]; then
  if [[ "$JSON_OUTPUT" == "true" ]]; then
    exec python3 "$ORACLE_PY" "$QUERY" --json
  else
    exec python3 "$ORACLE_PY" "$QUERY"
  fi
fi

# Fallback: ripgrep-based search (fast, respects .gitignore)
echo "═══════════════════════════════════════════"
echo "  Repo Oracle — Searching: ${QUERY}"
echo "═══════════════════════════════════════════"

SEARCH_DIRS=(
  "${REPO_ROOT}/packages"
  "${REPO_ROOT}/scripts"
  "${REPO_ROOT}/.agents/skills"
  "${REPO_ROOT}/libs"
  "${REPO_ROOT}/apps"
  "${REPO_ROOT}/tool_contracts"
)

FOUND=0

# Use ripgrep if available (fast, respects .gitignore)
if command -v rg &>/dev/null; then
  for dir in "${SEARCH_DIRS[@]}"; do
    if [[ -d "$dir" ]]; then
      while IFS= read -r file; do
        FOUND=$((FOUND + 1))
        rel_path="${file#"${REPO_ROOT}/"}"
        echo "  ✓ ${rel_path}"
      done < <(rg -l -i \
        --glob '*.py' --glob '*.sh' --glob '*.ts' --glob '*.tsx' --glob '*.yaml' --glob '*.yml' --glob '*.md' \
        --glob '!node_modules/**' --glob '!.next/**' --glob '!.venv/**' --glob '!__pycache__/**' \
        --glob '!*.min.js' --glob '!dist/**' --glob '!build/**' \
        "$QUERY" "$dir" 2>/dev/null || true)
    fi
  done
else
  # Fallback: grep with exclusions
  EXCLUDE_DIRS="--exclude-dir=node_modules --exclude-dir=.next --exclude-dir=.venv --exclude-dir=__pycache__ --exclude-dir=dist --exclude-dir=build --exclude-dir=.git"
  for dir in "${SEARCH_DIRS[@]}"; do
    if [[ -d "$dir" ]]; then
      while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        FOUND=$((FOUND + 1))
        rel_path="${file#"${REPO_ROOT}/"}"
        echo "  ✓ ${rel_path}"
      done < <(grep -rl $EXCLUDE_DIRS \
        --include="*.py" --include="*.sh" --include="*.ts" --include="*.yaml" --include="*.md" \
        -i "$QUERY" "$dir" 2>/dev/null || true)
    fi
  done
fi

echo "  ─────────────────────────────────────────"
echo "  Matches found: ${FOUND}"
echo "═══════════════════════════════════════════"

if [[ "$FOUND" -gt 0 ]]; then
  echo "  ⚠ Existing implementations detected. Review before creating new code."
fi
