{
  "mcpServers": {
    "google-developer-knowledge": {
      "serverUrl": "https://developer-knowledge.googleapis.com/mcp/",
      "authProviderType": "google_credentials"
    },
    "firebase": {
      "command": "npx",
      "args": ["-y", "firebase-tools@latest", "mcp"],
      "env": {
        "GOOGLE_CLOUD_PROJECT": "shadowtag-omega-v4",
        "GCLOUD_PROJECT": "shadowtag-omega-v4"
      }
    },
    "firestore": {
      "serverUrl": "https://firestore.googleapis.com/mcp",
      "authProviderType": "google_credentials"
    },
    "chrome-devtools-mcp": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-chrome-devtools", "--browser-url=http://127.0.0.1:9222", "--no-usage-statistics"]
    },
    "github-mcp": {
      "serverUrl": "https://api.github.com/mcp/",
      "oauth": {
        "clientId": "Iv23ctYqrxPQIt2ir8gY",
        "clientSecret": "OMITTED_FOR_SECURITY_USE_ENV_VAR"
      }
    },
    "stitch": {
      "command": "npx",
      "args": ["-y", "stitch-mcp"],
      "env": {
        "STITCH_API_KEY": "${STITCH_API_KEY}",
        "GOOGLE_CLOUD_PROJECT": "shadowtag-omega-v4"
      }
    },
    "gemini": {
      "command": "npx",
      "args": ["-y", "@houtini/gemini-mcp"],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    },
    "gcloud-mcp": {
      "command": "gcloud-mcp",
      "args": [],
      "env": {
        "CLOUDSDK_CORE_PROJECT": "shadowtag-omega-v4",
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/Users/pikeymickey/google-cloud-sdk/bin:/usr/bin:/bin"
      }
    },
    "mcp-toolbox-sdk-java": {
      "command": "java",
      "args": [
        "-jar",
        "/Users/pikeymickey/mcp-toolbox-sdk-java/target/mcp-toolbox-sdk-java-0.2.1-SNAPSHOT.jar"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "use_default_adc",
        "JAVA_HOME": "/Library/Java/JavaVirtualMachines/jdk-26.jdk/Contents/Home"
      }
    }
  }
}