{
  "panels": [
    {
      "id": 20,
      "title": "Error Budget Burn Rate",
      "type": "timeseries",
      "description": "Error budget consumption as % of monthly allowance (0.5% = 216 minutes)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "1 - (sum(rate(cloud_run_request_count{service_name=\"counselconduit\", response_code_class!=\"5xx\"}[5m])) / sum(rate(cloud_run_request_count{service_name=\"counselconduit\"}[5m])))",
          "legendFormat": "Error Rate",
          "refId": "A"
        },
        {
          "expr": "0.005",
          "legendFormat": "SLO Target (0.5%)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 0.02,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.003 },
              { "color": "red", "value": 0.005 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLO Target (0.5%)" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      }
    },
    {
      "id": 21,
      "title": "Error Budget Remaining (Monthly)",
      "type": "gauge",
      "description": "How much error budget is left for the current 30-day window",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "1 - ((sum(increase(cloud_run_request_count{service_name=\"counselconduit\", response_code_class=\"5xx\"}[30d])) / sum(increase(cloud_run_request_count{service_name=\"counselconduit\"}[30d]))) / 0.005)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.75 }
            ]
          }
        }
      },
      "options": {
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 22,
      "title": "Minutes of Downtime Allowed",
      "type": "stat",
      "description": "Remaining error budget in minutes (216 total for 99.5% SLO)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "216 * (1 - ((sum(increase(cloud_run_request_count{service_name=\"counselconduit\", response_code_class=\"5xx\"}[30d])) / sum(increase(cloud_run_request_count{service_name=\"counselconduit\"}[30d]))) / 0.005))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "yellow", "value": 100 },
              { "color": "green", "value": 150 }
            ]
          }
        }
      }
    },
    {
      "id": 23,
      "title": "Error Budget Burn Alerts History",
      "type": "state-timeline",
      "description": "When error budget burn rate exceeded normal thresholds",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "targets": [
        {
          "expr": "ALERTS{alertname=~\".*ErrorBudget.*|.*SLO.*\"}",
          "legendFormat": "{{alertname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 0, "fillOpacity": 70 }
        }
      }
    }
  ]
}
