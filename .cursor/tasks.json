{
  "version": "2.0",
  "tasks": [
    {
      "name": "router_start",
      "command": "cd router && npm run dev",
      "description": "Start multi-model router (:8787)"
    },
    {
      "name": "ace_triple_pass",
      "command": "cd tools/orchestrator && npm run triple:pass",
      "description": "Run ACE-inspired opposing-chain workflow"
    },
    {
      "name": "ingest_moondream",
      "command": "python -m ingestion.moondream_ingest",
      "description": "Run Moondream vision ingestion"
    },
    {
      "name": "computer_use_agent",
      "command": "python -m computer_use.agent",
      "description": "Run Gemini Computer-Use agent"
    },
    {
      "name": "safety_verify",
      "command": "python - <<'EOF'\nimport yaml, json, sys\nwith open('safety/risk_register.yaml') as f: yaml.safe_load(f)\nwith open('safety/monitoring/slos.json') as f: json.load(f)\nprint('✅ Safety framework valid')\nEOF",
      "description": "Validate safety framework files"
    },
    {
      "name": "test_python",
      "command": "pytest -v --tb=short",
      "description": "Run Python tests"
    },
    {
      "name": "test_node",
      "command": "npm test",
      "description": "Run Node.js tests"
    },
    {
      "name": "lint_python",
      "command": "ruff check . --fix",
      "description": "Lint and fix Python code with Ruff"
    },
    {
      "name": "format_python",
      "command": "ruff format .",
      "description": "Format Python code with Ruff"
    }
  ]
}
