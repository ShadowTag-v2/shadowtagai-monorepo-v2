rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /videos/{videoId} {
      allow read: if resource.data.status == 'PUBLISHED';
      allow write: if request.auth != null && request.auth.uid == resource.data.creatorId;
    }
    match /forensic_verdicts/{verdictId} {
      allow read: if true;
      allow write: if false;
    }
    match /human_telemetry/{telemetryId} {
      allow read: if false;
      allow create: if true;
      allow update, delete: if false;
    }
    match /licenses/{licenseId} {
      allow read: if request.auth != null && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      allow write: if false;
    }
    match /embed_telemetry/{telemetryId} {
      allow read: if request.auth != null && resource.data.publisherId == request.auth.uid;
      allow create: if true;
      allow update, delete: if false;
    }
  }
}
