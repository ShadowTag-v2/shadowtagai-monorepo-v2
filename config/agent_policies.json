{
  "version": "23.0.0",
  "mailbox_policies": {
    "max_vote_latency_ms": 150,
    "consensus_threshold": 0.85,
    "fallback_agent": "gemini-3.1-flash-lite-preview",
    "quarantine_untrusted_intents": true,
    "timeout_ms": 30000,
    "max_retries": 2
  },
  "agent_roles": {
    "security_reviewer": {
      "model": "gemini-3.1-flash-lite-preview",
      "veto_power": true,
      "required_for": ["auth_changes", "payment_changes", "secret_access"],
      "auto_approve_threshold": 0.95
    },
    "cost_analyst": {
      "model": "gemini-3.1-flash-lite-preview",
      "veto_power": false,
      "required_for": ["infrastructure_changes", "new_services", "database_migrations"],
      "auto_approve_threshold": 0.90
    },
    "architecture_board": {
      "model": "gemini-3.1-flash-lite-preview",
      "veto_power": true,
      "required_for": ["schema_changes", "api_surface_changes", "dependency_additions"],
      "auto_approve_threshold": 0.85
    }
  },
  "risk_escalation": {
    "low": ["cost_analyst"],
    "medium": ["cost_analyst", "architecture_board"],
    "high": ["security_reviewer", "cost_analyst", "architecture_board"],
    "critical": ["security_reviewer", "cost_analyst", "architecture_board"]
  }
}
